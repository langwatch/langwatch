ARG LAMBDA_ADAPTER_IMAGE=public.ecr.aws/awsguru/aws-lambda-adapter:0.9.1
FROM ${LAMBDA_ADAPTER_IMAGE} AS lambda-adapter

# Build the nlpgo Go binary. Lives in services/nlpgo/ + cmd/service/.
# The binary is a subcommand of the cmd/service multi-binary; we run
# `service nlpgo` at runtime via the entrypoint.
FROM golang:1.23-bookworm AS nlpgo-build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY pkg ./pkg
COPY services ./services
COPY cmd ./cmd
RUN CGO_ENABLED=0 GOOS=linux GOARCH=arm64 \
    go build -ldflags="-s -w" -o /out/service ./cmd/service

FROM python:3.12-slim-bookworm
COPY --from=lambda-adapter /lambda-adapter /opt/extensions/lambda-adapter

RUN apt-get update && apt-get install -y --no-install-recommends \
    libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

RUN pip install uv

WORKDIR /usr/src/app/python-sdk

COPY python-sdk .
RUN uv build

# Copy langevals_core for local path dependency
COPY langevals/langevals_core/ /usr/src/app/langevals/langevals_core/

WORKDIR /usr/src/app/langwatch_nlp

COPY langwatch_nlp/.python-version langwatch_nlp/uv.lock langwatch_nlp/pyproject.toml .
RUN uv sync --no-editable && uv pip uninstall litellm-enterprise litellm-proxy-extras

COPY langwatch_nlp .

# Preload for faster subsequent startups
RUN PYTHONPATH=. uv run --no-editable python langwatch_nlp/main.py

# Bring in the nlpgo binary as the front door (parallel deployment with
# the existing uvicorn process — see specs/nlp-go/_shared/contract.md §3).
# `service` is a multi-binary; the entrypoint runs it as the nlpgo
# subcommand. Set NLPGO_BYPASS=1 to skip it and run uvicorn directly.
COPY --from=nlpgo-build /out/service /usr/local/bin/nlpgo-service
RUN chmod +x /usr/local/bin/nlpgo-service \
    && printf '#!/bin/sh\nexec /usr/local/bin/nlpgo-service nlpgo "$@"\n' > /usr/local/bin/nlpgo \
    && chmod +x /usr/local/bin/nlpgo

COPY langwatch_nlp/scripts/entrypoint.sh /usr/local/bin/nlpgo-entrypoint.sh
RUN chmod +x /usr/local/bin/nlpgo-entrypoint.sh

ENV RUNNING_IN_DOCKER=true

EXPOSE 8080

CMD ["/usr/local/bin/nlpgo-entrypoint.sh"]
