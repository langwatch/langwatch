{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    // The evaluator catalog we import (langevals/ts-integration/evaluators.generated.ts)
    // is Zod-first and imports `zod`, but lives outside this package's
    // node_modules tree, so plain resolution cannot find it. Point `zod` at this
    // package's own copy (a declared dependency) so the type-checker resolves it.
    // Paths are resolved relative to this tsconfig (no baseUrl — tsgo removed it).
    "paths": { "zod": ["./node_modules/zod"] },
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "noUncheckedIndexedAccess": true,
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo"
  },
  "include": [
    ".eslintrc.cjs",
    "**/*.ts",
  ],
  "exclude": ["node_modules", "./dist/**/*", "./example/**/*"]
}
