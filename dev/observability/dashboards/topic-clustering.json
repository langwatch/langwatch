{
  "title": "Topic Clustering",
  "uid": "topic-clustering",
  "tags": ["langwatch", "topic-clustering", "adr-051", "adr-054"],
  "timezone": "utc",
  "schemaVersion": 39,
  "refresh": "5m",
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Run pages by outcome",
      "description": "topic_clustering_page_total — completed/skipped are healthy; failed_final fires TopicClusteringRunFailedFinal, and 24h of failures with zero completions fires TopicClusteringNothingCompleting.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (outcome) (increase(topic_clustering_page_total[1h]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Page duration by mode (p50 / p95)",
      "description": "topic_clustering_page_duration_milliseconds — a page is embeddings + LLM naming over up to 2000 traces; the outbox lease caps everything at 20 minutes.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, mode) (rate(topic_clustering_page_duration_milliseconds_bucket[6h])))",
          "legendFormat": "{{mode}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, mode) (rate(topic_clustering_page_duration_milliseconds_bucket[6h])))",
          "legendFormat": "{{mode}} p95"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Clustering outbox attempts by status",
      "description": "es_process_outbox_total{process_name=\"topicClustering\"} — retried under provider hiccups is expected; dead pages an operator.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (status) (increase(es_process_outbox_total{process_name=\"topicClustering\"}[1h]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Daily-wake lag (p50 / p95)",
      "description": "es_process_wake_lag_milliseconds{process_name=\"topicClustering\"} — how late the per-project daily slots actually fire.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(es_process_wake_lag_milliseconds_bucket{process_name=\"topicClustering\"}[6h])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(es_process_wake_lag_milliseconds_bucket{process_name=\"topicClustering\"}[6h])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Suppressed clustering intents",
      "description": "es_process_intents_suppressed_total{process_name=\"topicClustering\"} — the signature of a run-identity bug (a suppressed intent with currentRun set is a silently lost run).",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum (increase(es_process_intents_suppressed_total{process_name=\"topicClustering\"}[6h]))",
          "legendFormat": "suppressed"
        }
      ]
    }
  ]
}
