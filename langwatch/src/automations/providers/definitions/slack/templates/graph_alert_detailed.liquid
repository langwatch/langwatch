{%- capture _emoji -%}{% if trigger.alertType == 'INFO' %}ℹ️{% elsif trigger.alertType == 'CRITICAL' %}🔴{% else %}🚨{% endif %}{%- endcapture -%}
{%- capture _metric_field -%}
*Metric*
{{ metric.label | mrkdwn_escape }}
{%- endcapture -%}
{%- capture _condition_field -%}
*Condition*
{{ condition.operatorLabel }} {{ condition.threshold }} over the {{ condition.timePeriodLabel }}
{%- endcapture -%}
{%- capture _value_field -%}
*Current value*
{{ currentValue }}{% if previousValue != nil %} (was {{ previousValue }}){% endif %}
{%- endcapture -%}
{%- capture _history_lines -%}
{%- for point in history reversed limit: 8 -%}
`{{ point.timestamp | date: "%H:%M" }}`  {{ point.value }}{% unless forloop.last %}
{% endunless %}
{%- endfor -%}
{%- endcapture -%}
{%- capture _history_block -%}
*Recent values*
{{ _history_lines }}
{%- endcapture -%}
{%- capture _links -%}
<{{ graph.url }}|Open dashboard ↗> · <{{ trigger.editUrl }}|Edit automation>
{%- endcapture -%}
[
  { "type": "header", "text": { "type": "plain_text", "text": {{ trigger.name | truncate: 140 | prepend: " " | prepend: _emoji | json }}, "emoji": true } },
  { "type": "section", "fields": [
    { "type": "mrkdwn", "text": {{ _metric_field | json }} },
    { "type": "mrkdwn", "text": {{ _condition_field | json }} },
    { "type": "mrkdwn", "text": {{ _value_field | json }} }
  ] }
  {%- if reason == "heartbeat-absence" -%}
  ,{ "type": "section", "text": { "type": "mrkdwn", "text": "_No qualifying data was seen in the window._" } }
  {%- endif -%}
  {%- if sparkline != "" -%}
  ,{ "type": "context", "elements": [{ "type": "mrkdwn", "text": {{ sparkline | prepend: "Trend: `" | append: "`" | json }} }] }
  {%- endif -%}
  {%- if history != empty -%}
  ,{ "type": "divider" }
  ,{ "type": "section", "text": { "type": "mrkdwn", "text": {{ _history_block | json }} } }
  {%- endif -%}
  ,{ "type": "context", "elements": [{ "type": "mrkdwn", "text": {{ _links | json }} }] }
]
