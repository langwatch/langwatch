{%- comment -%}
  Rich trace card. Renders Input and Output as native rich_text_quote sub-blocks
  inside a single `rich_text` block — the native quoting primitive that replaces
  the "## User" markdown-block hack in trace_alert_compact.

  Escaping: a rich_text `text` element is a PLAIN string (Slack never parses
  mrkdwn inside it), so `| json` alone is the correct and sufficient escaping —
  it JSON-encodes the value and no markup forging is possible by construction.
  mrkdwn_escape is DELIBERATELY NOT applied to these text elements; it would
  double-escape a surface that never parses mrkdwn (turning `<` into a literal
  `&lt;`). The mrkdwn context blocks (eval line, footer) keep mrkdwn_escape on
  user-controlled fields as usual. Truncate runs before json so the char budget
  counts visible characters.
{%- endcomment -%}
{%- capture _header_text -%}
{% if match.evaluation.passed == false %}🛑 {% else %}🔔 {% endif %}{{ trigger.name }}
{%- endcapture -%}
{%- capture _ctx_eval -%}
{%- if match.evaluation %}*{{ match.evaluation.evaluatorName | default: "Evaluation" | mrkdwn_escape }}*{% if match.evaluation.score != null %} `{{ match.evaluation.score }}`{% endif %}{% if match.evaluation.label %} · {{ match.evaluation.label | mrkdwn_escape }}{% endif %}{% if match.evaluation.passed == false %} · *failed*{% elsif match.evaluation.passed == true %} · *passed*{% endif %}{%- endif -%}
{%- if match.evaluation and trigger.alertType %} · {% endif -%}
{%- if trigger.alertType %}_{{ trigger.alertType }}_{%- endif -%}
{%- endcapture -%}
{%- capture _footer -%}
`{{ match.trace.id | truncate: 12 }}`{% if match.trace.metadata.model %} · {{ match.trace.metadata.model | mrkdwn_escape }}{% endif %}{% if match.trace.metadata.duration_ms %} · {{ match.trace.metadata.duration_ms }}ms{% endif %}{% if match.trace.metadata.cost %} · ${{ match.trace.metadata.cost }}{% endif %} · <{{ match.trace.url }}|View trace ↗>
{%- endcapture -%}
{%- assign _input = match.trace.input | truncate: 1500 -%}
{%- assign _output = match.trace.output | truncate: 1500 -%}
{%- capture _rt_body -%}
{%- if _input != "" -%}
{ "type": "rich_text_section", "elements": [{ "type": "text", "text": "Input", "style": { "bold": true } }] },
{ "type": "rich_text_quote", "elements": [{ "type": "text", "text": {{ _input | json }} }] }
{%- endif -%}
{%- if _input != "" and _output != "" -%},{%- endif -%}
{%- if _output != "" -%}
{ "type": "rich_text_section", "elements": [{ "type": "text", "text": "Output", "style": { "bold": true } }] },
{ "type": "rich_text_quote", "elements": [{ "type": "text", "text": {{ _output | json }} }] }
{%- endif -%}
{%- endcapture -%}
[
  { "type": "header", "text": { "type": "plain_text", "text": {{ _header_text | truncate: 140 | json }}, "emoji": true } }
  {%- if _ctx_eval != "" -%}
  ,{ "type": "context", "elements": [{ "type": "mrkdwn", "text": {{ _ctx_eval | json }} }] }
  {%- endif -%}
  {%- if _rt_body != "" -%}
  ,{ "type": "rich_text", "elements": [ {{ _rt_body }} ] }
  {%- endif -%}
  ,{ "type": "context", "elements": [{ "type": "mrkdwn", "text": {{ _footer | json }} }] }
]
