{%- assign chart = charts | first -%}
{%- capture _sub -%}
{{ chart.title | default: report.sourceLabel | mrkdwn_escape }} · {{ report.scheduleLabel }}
{%- endcapture -%}
{%- capture _chart_json -%}
{%- if chart.type == "pie" -%}
{ "type": "pie", "segments": [
{%- for seg in chart.segments limit: 8 -%}
{% unless forloop.first %},{% endunless %}{ "label": {{ seg.label | truncate: 40 | json }}, "value": {{ seg.value }} }
{%- endfor -%}
] }
{%- else -%}
{ "type": {{ chart.type | json }}, "series": [
{%- for s in chart.series limit: 5 -%}
{% unless forloop.first %},{% endunless %}{ "name": {{ s.name | truncate: 20 | json }}, "data": [
{%- for p in s.data limit: 20 -%}
{% unless forloop.first %},{% endunless %}{ "label": {{ p.label | json }}, "value": {{ p.value }} }
{%- endfor -%}
] }
{%- endfor -%}
], "axis_config": { "categories": [
{%- for c in chart.categories limit: 20 -%}
{% unless forloop.first %},{% endunless %}{{ c | json }}
{%- endfor -%}
], "x_label": "Time", "y_label": {{ chart.title | truncate: 50 | json }} } }
{%- endif -%}
{%- endcapture -%}
{%- assign _series_count = chart.series | size -%}
{%- capture _headline -%}
*{{ chart.total | round: 2 }}* over this period{% if _series_count > 1 %} · {{ _series_count }} series{% endif %}
{%- endcapture -%}
{%- capture _view -%}
<{{ viewUrl }}|Open in LangWatch ↗> · {{ occurredAt | date: "%b %d, %H:%M" }}
{%- endcapture -%}
[
  { "type": "header", "text": { "type": "plain_text", "text": {{ trigger.name | prepend: "📈 " | truncate: 140 | json }}, "emoji": true } },
  { "type": "context", "elements": [{ "type": "mrkdwn", "text": {{ _sub | json }} }] }
  {%- if report.isEmpty -%}
  ,{ "type": "section", "text": { "type": "mrkdwn", "text": "_No data for this period._" } }
  {%- else -%}
  ,{ "type": "data_visualization", "block_id": "report_chart", "title": {{ chart.title | truncate: 50 | json }}, "chart": {{ _chart_json }} }
  ,{ "type": "section", "text": { "type": "mrkdwn", "text": {{ _headline | json }} } }
  {%- endif -%}
  ,{ "type": "context", "elements": [{ "type": "mrkdwn", "text": {{ _view | json }} }] }
]
