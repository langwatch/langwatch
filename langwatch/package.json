{
  "name": "langwatch",
  "version": "3.5.0",
  "private": true,
  "engines": {
    "node": "24.x",
    "npm": ">=10.0.0"
  },
  "volta": {
    "node": "24.13.0",
    "pnpm": "10.24.0"
  },
  "scripts": {
    "tool:deja-view": "NODE_ENV=development pnpm --filter @langwatch/deja-view dev",
    "tool:stressed-n-blessed": "NODE_ENV=development pnpm --filter @langwatch/stressed-n-blessed dev",
    "build:scenario-child-process": "node scripts/build-scenario-child-process.mjs",
    "build": "pnpm run start:prepare:files && pnpm run build:scenario-child-process && NODE_ENV=production BUILD_TIME=1 vite build",
    "build:client": "NODE_ENV=production vite build",
    "tool:analytics-parity-check": "NODE_ENV=development pnpm --filter @langwatch/analytics-parity-check",
    "lint": "pnpm exec biome check src/",
    "lint:fix": "pnpm exec biome check src/ --write",
    "check:feature-parity": "tsx scripts/check-feature-parity.ts",
    "format": "pnpm exec biome format src/ --write",
    "postinstall": "make -C .. setup-hooks 2>/dev/null || true",
    "dev": "NODE_ENV=development START_WORKERS=true ./scripts/check-ports.sh && pnpm run start:prepare:files && NODE_ENV=development START_WORKERS=true FORCE_COLOR=1 pnpm start 2>&1 | tee server.log",
    "dev:single": "WORKERS_IN_PROCESS=1 pnpm dev",
    "dev:haven": "NODE_ENV=development START_WORKERS=true FORCE_COLOR=1 go run github.com/langwatch/langwatch/cmd/haven up 2>&1 | tee server.log",
    "dev:single:haven": "WORKERS_IN_PROCESS=1 pnpm dev:haven",
    "dev:workers:haven": "WORKERS_IN_PROCESS=0 pnpm dev:haven",
    "dev:vite": "vite",
    "dev:clean": "rm -rf node_modules/.vite .dev-certs && echo 'Vite cache and dev certs cleared. Restart dev server.'",
    "start": "./scripts/start.sh",
    "start:app": "tsx src/server.mts",
    "start:prepare:files": "pnpm run ensure:ai-gateway-secrets && pnpm run copy:langevals-types && pnpm run prisma:generate:typescript && pnpm run build:mcp-server",
    "ensure:ai-gateway-secrets": "bash scripts/ensure-ai-gateway-secrets.sh",
    "build:mcp-server": "./scripts/build-mcp-server.sh",
    "start:prepare:db": "pnpm run prisma:migrate && pnpm run clickhouse:migrate",
    "start:workers": "tsx --tsconfig tsconfig.workers.json src/workers.ts",
    "typecheck:legacy": "./node_modules/.bin/tsc --noEmit --project ./tsconfig.json",
    "typecheck": "./node_modules/.bin/tsgo --noEmit --project ./tsconfig.tsgo.json",
    "typecheck:tests": "./node_modules/.bin/tsgo --noEmit --project ./tsconfig.tsgo.tests.json",
    "typecheck:all": "pnpm run typecheck && pnpm run typecheck:tests",
    "test:unit": "NODE_ENV=test PINO_LOG_LEVEL=warn vitest",
    "test:browser": "NODE_ENV=test PINO_LOG_LEVEL=warn vitest -c vitest.browser.config.ts",
    "test:ci": "pnpm run test:unit",
    "test:integration": "NODE_ENV=test PINO_LOG_LEVEL=warn vitest -c vitest.integration.config.ts",
    "test:pg-integration": "NODE_ENV=test PINO_LOG_LEVEL=warn vitest -c vitest.pg-integration.config.ts",
    "test:stress": "NODE_ENV=test PINO_LOG_LEVEL=warn vitest -c vitest.stress.config.ts",
    "test:stripe-integration": "NODE_ENV=test PINO_LOG_LEVEL=warn vitest -c vitest.stripe-integration.config.ts",
    "task": " tsx --tsconfig tsconfig.workers.json src/task.ts",
    "task:backfill-datasets-s3": "pnpm run task backfillDatasetContentToS3",
    "prisma:generate:typescript": "pnpm prisma generate",
    "prisma:generate:migration": "pnpm prisma migrate dev --create-only",
    "prisma:migrate": "sh -c 'if [ \"$SKIP_PRISMA_MIGRATE\" != \"true\" ]; then pnpm prisma migrate deploy; else echo \"Skipping Prisma migrations\"; fi'",
    "prisma:seed": "tsx prisma/seed.ts",
    "seed:sample-traces": "tsx scripts/seed-sample-traces.ts",
    "clickhouse:migrate": "sh -c 'if [ \"$SKIP_CLICKHOUSE_MIGRATE\" != \"true\" ]; then pnpm run task clickhouseMigrate; else echo \"Skipping ClickHouse migrations\"; fi'",
    "copy:langevals-types": "cp ../langevals/ts-integration/evaluators.generated.ts src/server/evaluations/evaluators.generated.ts",
    "tsc-watch": "tsc --noEmit --watch",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:save-auth-state": "tsx e2e/save-auth-state.ts",
    "test:e2e:codegen": "playwright codegen --load-storage=./e2e/auth.json http://localhost:5560/",
    "test:e2e:langevals-staging": "bash -c 'eval \"$(aws --profile ${AWS_PROFILE:-lw-dev} configure export-credentials --format env)\" && S3_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID S3_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY S3_SESSION_TOKEN=$AWS_SESSION_TOKEN S3_BUCKET_NAME=${S3_BUCKET_NAME:-runtime-storage-dev} S3_REGION=${S3_REGION:-eu-central-1} LANGEVALS_E2E_ENABLED=1 LANGEVALS_STAGING_THRESHOLD_BYTES=200 EVAL_MAX_PAYLOAD_BYTES=20000000 TOPIC_CLUSTERING_MAX_PAYLOAD_BYTES=200000000 vitest run src/server/langevals/__tests__/stagedFetch.e2e.test.ts --reporter verbose'",
    "licenses": "pnpx license-checker --summary && pnpx license-checker --json > licenses.json && echo \"Full licenses report saved to licenses.json\""
  },
