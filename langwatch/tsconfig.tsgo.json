{
	"compilerOptions": {
		"target": "es2020",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"checkJs": true,
		"skipLibCheck": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"moduleDetection": "force",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "preserve",
		"incremental": true,
		"tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo/tsgo-app.tsbuildinfo",
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"paths": {
			"~/*": ["./src/*"],
			"@ee/*": ["./ee/*"],
			"@app/*": ["./src/server/app-layer/*"],
			"@trpc-internal/parser": ["./node_modules/@trpc/server/dist/core/parser"],
			"@trpc-internal/utils": [
				"./node_modules/@trpc/server/dist/core/internals/utils"
			],
			"zod/lib/helpers/errorUtil": ["./node_modules/zod/lib/helpers/errorUtil"]
		},
		"plugins": [
			{
				"name": "next"
			}
		]
	},
	// Workspace packages are composite projects (repo-root /packages). With
	// these references, imports of @langwatch/* resolve to each package's
	// emitted dist/*.d.ts instead of pulling its sources (and their deps) into
	// this program — skipLibCheck then makes them parse-only. Build them first:
	// `tsgo --build` handles ordering + staleness (pnpm typecheck does this).
	"references": [
		{ "path": "../packages/api" },
		{ "path": "../packages/automations" },
		{ "path": "../packages/observability" },
		{ "path": "../packages/ssrf" },
		{ "path": "../packages/cli-cards" },
		{ "path": "../packages/handled-error" }
	],
	// Deliberately narrow: only app source trees are ROOT files. Tooling that
	// used to ride in on `**/*.ts` (scripts/, vitest*.config.ts, vite/,
	// prisma/ seeds, test-setup*) lives in tsconfig.tooling.json now, keeping
	// vitest/vite/playwright types out of this program. Anything src imports
	// is still pulled in transitively regardless of these globs.
	"include": [
		"./src/**/*",
		"./ee/**/*",
		".eslintrc.cjs",
		"next-env.d.ts",
		".next/types/**/*.ts",
		".next-saas/types/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"../mcp-server",
		".next",
		".next-saas",
		"**/*.snippet.*",
		"src/**/codegen/snippets/**/*",
		"**/*.test.ts",
		"**/*.test.tsx",
		"**/*.spec.ts",
		"**/*.spec.tsx",
		"**/__tests__/**",
		"**/__mocks__/**",
		"e2e/**"
	]
}
