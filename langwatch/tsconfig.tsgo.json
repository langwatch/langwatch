{
	"compilerOptions": {
		"target": "es2020",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"checkJs": true,
		"skipLibCheck": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"moduleDetection": "force",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "preserve",
		"incremental": true,
		"tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo/tsgo-app.tsbuildinfo",
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"paths": {
			"~/*": ["./src/*"],
			"@ee/*": ["./ee/*"],
			"@app/*": ["./src/server/app-layer/*"],
			"@trpc-internal/parser": ["./node_modules/@trpc/server/dist/core/parser"],
			"@trpc-internal/utils": [
				"./node_modules/@trpc/server/dist/core/internals/utils"
			],
			"zod/lib/helpers/errorUtil": ["./node_modules/zod/lib/helpers/errorUtil"]
		},
		"plugins": [
			{
				"name": "next"
			}
		]
	},
	// This project's include/exclude intentionally mirrors the historically
	// green config (no tooling exclusions). Excluding the vite/vitest config
	// files broke how `vite/client`'s ambient declarations (import.meta.env,
	// *.css, *?raw) apply to a handful of files at full-program scale — a
	// subtle interaction not worth chasing here. The @langwatch/* workspace
	// packages moved OUT of langwatch/ (to repo-root /packages), so the
	// `**/*.ts` glob no longer sweeps them; they are validated separately by
	// `pnpm typecheck:packages`. Checked with `-p` (not `tsgo --build`):
	// @langwatch/* resolves to source via the pnpm workspace symlink, exactly
	// as the app already resolved cli-cards / handled-error.
	"include": [
		"./src/**/*",
		"./ee/**/*",
		".eslintrc.cjs",
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		"**/*.cjs",
		"**/*.mjs",
		".next/types/**/*.ts",
		".next-saas/types/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"../mcp-server",
		".next",
		".next-saas",
		"**/*.snippet.*",
		"src/**/codegen/snippets/**/*",
		"**/*.test.ts",
		"**/*.test.tsx",
		"**/*.spec.ts",
		"**/*.spec.tsx",
		"**/__tests__/**",
		"**/__mocks__/**",
		"e2e/**"
	]
}
