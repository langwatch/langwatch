{
	"compilerOptions": {
		"target": "es2020",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"checkJs": true,
		"skipLibCheck": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"moduleDetection": "force",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "preserve",
		"incremental": true,
		"tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo/tsgo-app.tsbuildinfo",
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"paths": {
			"~/*": ["./src/*"],
			"@ee/*": ["./ee/*"],
			"@app/*": ["./src/server/app-layer/*"],
			"@trpc-internal/parser": ["./node_modules/@trpc/server/dist/core/parser"],
			"@trpc-internal/utils": [
				"./node_modules/@trpc/server/dist/core/internals/utils"
			],
			"zod/lib/helpers/errorUtil": ["./node_modules/zod/lib/helpers/errorUtil"]
		},
		"plugins": [
			{
				"name": "next"
			}
		]
	},
	// NOTE: no `references` here, and this project is checked with `-p`
	// (not `tsgo --build`). Under `--build`, the referenced-project output
	// redirection changed how `vite/client`'s ambient declarations
	// (import.meta.env, *.css, *?raw) resolve at full-program scale — a
	// handful of files silently lost them. Resolving @langwatch/* to source
	// via the pnpm workspace symlink (as the app already did for cli-cards /
	// handled-error) is the historically-green behavior. Packages get their
	// own composite build via `pnpm typecheck:packages`.
	// Broad include (matches the historically-green config) so ambient
	// declarations resolve identically — a narrowed src-only include silently
	// changed how `vite/client`'s asset/import.meta ambients apply at
	// full-program scale. The RAM win (keeping vitest/vite/playwright/rolldown
	// types out) is kept by EXCLUDING the tooling below, not by omitting it
	// from the include. Those same files are the root set of
	// tsconfig.tooling.json.
	"include": [
		"./src/**/*",
		"./ee/**/*",
		".eslintrc.cjs",
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		"**/*.cjs",
		"**/*.mjs",
		".next/types/**/*.ts",
		".next-saas/types/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"../mcp-server",
		".next",
		".next-saas",
		"**/*.snippet.*",
		"src/**/codegen/snippets/**/*",
		"**/*.test.ts",
		"**/*.test.tsx",
		"**/*.spec.ts",
		"**/*.spec.tsx",
		"**/__tests__/**",
		"**/__mocks__/**",
		"e2e/**",
		// Tooling — checked by tsconfig.tooling.json, kept out here so their
		// deps' types (vitest, vite, playwright, rolldown) stay off the app graph.
		"scripts/**",
		"vite/**",
		"prisma/**",
		"vite.config.ts",
		"vitest.config.ts",
		"vitest.browser.config.ts",
		"vitest.integration.config.ts",
		"vitest.mcp.config.ts",
		"vitest.pg-integration.config.ts",
		"vitest.prisma-integration.config.ts",
		"vitest.stress.config.ts",
		"vitest.stripe-integration.config.ts",
		"test-setup.ts",
		"test-setup.browser.ts"
	]
}
