// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
  // Further reading:
  // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// BetterAuth-compatible Account. Column names preserved; BetterAuth's field
// mapping in src/server/better-auth/index.ts points its expected names at
// these columns. `password` is new — credential passwords moved here from
// `User.password` in the better_auth_cutover migration.
model Account {
  id                String    @id @default(nanoid())
  userId            String
  type              String    @default("oauth")
  provider          String
  providerAccountId String
  refresh_token     String?   @db.Text
  access_token      String?   @db.Text
  expires_at        DateTime?
  ext_expires_in    Int?
  token_type        String?
  scope             String?
  id_token          String?   @db.Text
  session_state     String?
  password          String?   @db.Text
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id            String   @id @default(nanoid())
  sessionToken  String   @unique
  userId        String
  expires       DateTime
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonating Json?
  ipAddress     String?
  userAgent     String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@index([userId])
}

model User {
  id                      String                   @id @default(nanoid())
  name                    String?
  email                   String?                  @unique
  emailVerified           Boolean                  @default(false)
  image                   String?                  @db.Text
  pendingSsoSetup         Boolean                  @default(false)
  accounts                Account[]
  sessions                Session[]
  teamMemberships         TeamUser[]
  orgMemberships          OrganizationUser[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @default(now()) @updatedAt
  lastLoginAt             DateTime?
  deactivatedAt           DateTime?
  // User-level pin for the persona-resolver redirect target. NULL = use
  // auto-detection. When set, wins over auto-detected persona destination.
  // Spec: specs/ai-gateway/governance/persona-home-content.feature
  lastHomePath            String?
  Annotation              Annotation[]
  publicShares            PublicShare[]
  Workflow                Workflow[]
  WorkflowVersion         WorkflowVersion[]
  annotationQueues        AnnotationQueueMembers[]
  assignedQueueItems      AnnotationQueueItem[]    @relation("AssignedTo")
  createdQueueItems       AnnotationQueueItem[]    @relation("CreatedBy")
  llmPromptConfigVersions LlmPromptConfigVersion[]
  scenarios               Scenario[]
  inviteRequests          OrganizationInvite[]
  secretsCreated          ProjectSecret[]          @relation("secretCreatedBy")
  secretsUpdated          ProjectSecret[]          @relation("secretUpdatedBy")
  savedViews              SavedView[]
  versionTagsCreated      PromptTagAssignment[]    @relation("versionTagCreatedBy")
  versionTagsUpdated      PromptTagAssignment[]    @relation("versionTagUpdatedBy")
  promptTagsCreated       PromptTag[]              @relation("promptTagCreatedBy")
  promptTagsUpdated       PromptTag[]              @relation("promptTagUpdatedBy")
  groupMemberships        GroupMembership[]
  roleBindings            RoleBinding[]
  apiKeys                 ApiKey[]
  gatewayBudgetsCreated   GatewayBudget[]          @relation("GatewayBudgetCreatedBy")
  principalGatewayBudgets GatewayBudget[]          @relation("PrincipalScopedGatewayBudgets")
  principalVirtualKeys    VirtualKey[]             @relation("PrincipalScopedVirtualKeys")
  personalTeams           Team[]                   @relation("PersonalTeamOwner")
  personalProjects        Project[]                @relation("PersonalProjectOwner")
  routingPoliciesCreated  RoutingPolicy[]          @relation("RoutingPolicyCreatedBy")
  routingPoliciesUpdated  RoutingPolicy[]          @relation("RoutingPolicyUpdatedBy")
  gatewayGuardrailsCreated GatewayGuardrail[]      @relation("GatewayGuardrailCreatedBy")
  gatewayGuardrailsUpdated GatewayGuardrail[]      @relation("GatewayGuardrailUpdatedBy")
  ingestionSourcesCreated IngestionSource[]        @relation("IngestionSourceCreatedBy")
  anomalyRulesCreated     AnomalyRule[]            @relation("AnomalyRuleCreatedBy")
  userIngestionBindings   UserIngestionBinding[]
}

model VerificationToken {
  id         String   @id @default(nanoid())
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@unique([identifier, token])
}

enum TeamUserRole {
  ADMIN
  MEMBER
  VIEWER
  CUSTOM
}

// Scoped RBAC — scope levels for RoleBinding
enum RoleBindingScopeType {
  ORGANIZATION
  TEAM
  PROJECT
}

enum OrganizationUserRole {
  ADMIN
  MEMBER
  EXTERNAL
}

model TeamUser {
  userId         String
  teamId         String
  role           TeamUserRole
  assignedRoleId String?
  assignedRole   CustomRole?  @relation(fields: [assignedRoleId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  team           Team         @relation(fields: [teamId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt

  @@id([userId, teamId])
  @@index([teamId])
  @@index([userId])
  @@index([assignedRoleId])
}

model OrganizationUser {
  userId         String
  organizationId String
  role           OrganizationUserRole
  user           User                 @relation(fields: [userId], references: [id])
  organization   Organization         @relation(fields: [organizationId], references: [id])
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @default(now()) @updatedAt

  @@id([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Team {
  id             String          @id @default(nanoid())
  name           String
  slug           String          @unique
  members        TeamUser[]
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  projects       Project[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @default(now()) @updatedAt
  archivedAt     DateTime?
  gatewayBudgets GatewayBudget[] @relation("TeamScopedGatewayBudgets")

  // Personal workspace per (org, user). Created on user's first
  // visit to an org. UI hides isPersonal=true teams from team
  // pickers; they surface under "My Workspace" instead.
  isPersonal  Boolean @default(false)
  ownerUserId String? @db.VarChar(255)
  ownerUser   User?   @relation("PersonalTeamOwner", fields: [ownerUserId], references: [id])

  ingestionSources IngestionSource[]
  aiToolEntryTeams AiToolEntryTeam[]

  @@index([organizationId])
  @@index([isPersonal])
}

model Organization {
  id                       String               @id @default(nanoid())
  name                     String
  phoneNumber              String?
  slug                     String               @unique
  members                  OrganizationUser[]
  teams                    Team[]
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @default(now()) @updatedAt
  OrganizationInvite       OrganizationInvite[]
  usageSpendingMaxLimit    Int?
  /// Phase 8 — admin-configurable max lifetime for CLI device-flow
  /// sessions, in days. 0 = unbounded (default, mirrors GitHub CLI /
  /// gh-style flows). Companies that need finite session lifetime
  /// (eg. SOC 2 / ISO 27001 customers with mandated session
  /// expiration) can set a positive value. The /api/auth/cli/refresh
  /// endpoint rejects refresh attempts where now - issued_at exceeds
  /// this value, regardless of the underlying refresh-token TTL.
  /// Spec: specs/ai-governance/sessions/session-ttl.feature.
  maxSessionDurationDays   Int                  @default(0)
  /// Phase 9 — receiver-side gen_ai content stripping ("no-spy mode").
  /// Values:
  ///   "full"      (default) — store all content in CH (current behavior)
  ///   "strip_io"  — drop gen_ai.prompt + gen_ai.completion + gen_ai.system_message
  ///                 from gateway-origin spans BEFORE the CH write
  ///   "strip_all" — strip_io + tool_call.arguments + tool_result.content
  /// Forward-looking only: changes do not retroactively scrub historical
  /// content; existing rows remain stored. Only applies to spans with
  /// `langwatch.origin = "gateway"`; user-app traces are untouched so
  /// customer-controlled data flows continue to work unchanged.
  /// Spec: specs/ai-governance/no-spy-mode/no-spy-mode.feature.
  governanceLogContentMode String               @default("full")
  signupData               Json?
  signedDPA                Boolean              @default(false)
  elasticsearchNodeUrl     String?
  elasticsearchApiKey      String?
  useCustomElasticsearch   Boolean              @default(false)
  s3Endpoint               String?
  s3AccessKeyId            String?
  s3SecretAccessKey        String?
  s3Bucket                 String?
  useCustomS3              Boolean              @default(false)
  sentPlanLimitAlert       DateTime?
  ssoDomain                String?              @unique
  ssoProvider              String?
  presenceEnabled          Boolean              @default(true)

  promoCode              String?
  stripeCustomerId       String?                @unique
  currency               Currency               @default(EUR)
  pricingModel           PricingModel           @default(TIERED)
  CustomRoles            CustomRole[]
  notifications          Notification[]
  subscriptions          Subscription[]
  scimTokens             ScimToken[]
  promptTags             PromptTag[]
  groups                 Group[]
  roleBindings           RoleBinding[]
  apiKeys                ApiKey[]
  // License enforcement fields (COSS-0226)
  license                String?                @db.Text
  licenseExpiresAt       DateTime?
  licenseLastValidatedAt DateTime?
  gatewayBudgets         GatewayBudget[]        @relation("OrgScopedGatewayBudgets")
  gatewayChangeEvents    GatewayChangeEvent[]
  routingPolicies        RoutingPolicy[]
  ingestionSources       IngestionSource[]
  anomalyRules           AnomalyRule[]
  anomalyAlerts          AnomalyAlert[]
  aiToolEntries          AiToolEntry[]
  ingestionTemplates     IngestionTemplate[]
  userIngestionBindings  UserIngestionBinding[]

  @@index([ssoProvider])
}

model ScimToken {
  id             String       @id @default(nanoid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hashedToken    String
  description    String?
  createdAt      DateTime     @default(now())
  lastUsedAt     DateTime?

  @@index([organizationId])
  @@index([hashedToken])
}

enum PlanTypes {
  FREE
  PRO
  GROWTH
  GROWTH_SEAT_EUR_MONTHLY
  GROWTH_SEAT_EUR_ANNUAL
  GROWTH_SEAT_USD_MONTHLY
  GROWTH_SEAT_USD_ANNUAL
  ENTERPRISE
  LAUNCH
  ACCELERATE
  LAUNCH_ANNUAL
  ACCELERATE_ANNUAL
}

enum PricingModel {
  TIERED
  SEAT_EVENT
}

enum SubscriptionStatus {
  PENDING
  FAILED
  ACTIVE
  CANCELLED
}

enum Currency {
  USD
  EUR
}

enum PIIRedactionLevel {
  STRICT
  ESSENTIAL
  DISABLED
}

enum ProjectSensitiveDataVisibilityLevel {
  REDACTED_TO_ALL
  VISIBLE_TO_ADMIN
  VISIBLE_TO_ALL
}

model Project {
  id                       String                              @id @default(nanoid())
  name                     String
  slug                     String                              @unique
  apiKey                   String                              @unique
  teamId                   String
  team                     Team                                @relation(fields: [teamId], references: [id])
  language                 String
  framework                String
  /// Project kind:
  ///   - "application": user-facing workspace where developers send their
  ///     own app traces. The default for everything created via the
  ///     onboarding/quickstart flow.
  ///   - "internal_governance": hidden per-org routing/tenancy artifact
  ///     for IngestionSource ingest data. Auto-created lazily on the
  ///     first IngestionSource mint via ensureHiddenGovernanceProject().
  ///     MUST be filtered out of every user-visible Project surface
  ///     (project picker, /api/v1/projects, billing exports, RBAC
  ///     pickers, etc.) — the regression-test invariant in
  ///     specs/ai-gateway/governance/ui-contract.feature codifies this.
  /// Stored as a free-form string (matching IngestionSource.sourceType
  /// pattern) so future routing kinds can ship without schema migrations.
  kind                     String                              @default("application")
  firstMessage             Boolean                             @default(false)
  integrated               Boolean                             @default(false)
  createdAt                DateTime                            @default(now())
  updatedAt                DateTime                            @default(now()) @updatedAt
  userLinkTemplate         String?
  checks                   Monitor[]
  costs                    Cost[]
  topics                   Topic[]
  datasets                 Dataset[]
  datasetRecords           DatasetRecord[]
  customGraphs             CustomGraph[]
  dashboards               Dashboard[]
  batchEvaluations         BatchEvaluation[]
  piiRedactionLevel        PIIRedactionLevel                   @default(ESSENTIAL)
  capturedInputVisibility  ProjectSensitiveDataVisibilityLevel @default(VISIBLE_TO_ALL)
  capturedOutputVisibility ProjectSensitiveDataVisibilityLevel @default(VISIBLE_TO_ALL)
  traceSharingEnabled      Boolean                             @default(true)
  presenceEnabled          Boolean                             @default(true)
  triggers                 Trigger[]
  experiments              Experiment[]
  annotations              Annotation[]
  projectSecrets           ProjectSecret[]
  TriggerSent              TriggerSent[]
  ReactorOutbox            ReactorOutbox[]
  annotationScores         AnnotationScore[]
  publicShares             PublicShare[]
  workflows                Workflow[]
  WorkflowVersion          WorkflowVersion[]
  AnnotationQueue          AnnotationQueue[]
  AnnotationQueueItem      AnnotationQueueItem[]
  s3Endpoint               String?
  s3AccessKeyId            String?
  s3SecretAccessKey        String?
  s3Bucket                 String?
  llmPromptConfigs         LlmPromptConfig[]
  analytics                Analytics[]
  archivedAt               DateTime?
  notifications            Notification[]
  agents                   Agent[]
  evaluators               Evaluator[]
  scenarios                Scenario[]
  suiteConfigurations      SimulationSuite[]
  savedViews               SavedView[]
  gatewayBudgets           GatewayBudget[]                     @relation("ProjectScopedGatewayBudgets")
  gatewayGuardrails        GatewayGuardrail[]                  @relation("ProjectGatewayGuardrails")
  gatewayChangeEvents      GatewayChangeEvent[]
  userIngestionBindings    UserIngestionBinding[]

  // Denormalised mirror of parent Team's personal flag for fast
  // lookup at trace ingest time without a Team join. Always equals
  // the parent Team.isPersonal value; PersonalWorkspaceService
  // sets both atomically.
  isPersonal  Boolean @default(false)
  ownerUserId String? @db.VarChar(255)
  ownerUser   User?   @relation("PersonalProjectOwner", fields: [ownerUserId], references: [id])

  /// Per-feature unlock flags for personal projects only. Shape:
  /// `{ evaluations: bool, datasets: bool, annotations: bool, automations: bool }`.
  /// Empty `{}` (default) reads as all-false at the service layer —
  /// existing rows pre-migration require no backfill. The bundle is
  /// a UI/nav predicate, NOT an auth gate (the underlying tRPC
  /// routers stay open even when the bundle is off; admin tooling +
  /// offline migration scripts can still operate on the data).
  /// Team / org-scope projects are not feature-gated — this column
  /// is meaningful only when `isPersonal=true`.
  personalFeatures Json @default("{}")

  @@index([teamId])
  @@index([isPersonal])
  @@index([ownerUserId])
  @@index([teamId, kind])
}

enum INVITE_STATUS {
  PENDING
  ACCEPTED
  WAITING_APPROVAL
  PAYMENT_PENDING
}

model OrganizationInvite {
  id              String               @id @default(nanoid())
  email           String
  inviteCode      String               @unique
  expiration      DateTime?
  status          INVITE_STATUS        @default(PENDING)
  organizationId  String
  organization    Organization         @relation(fields: [organizationId], references: [id])
  teamIds         String
  teamAssignments Json? // Array of {teamId: string, role: TeamUserRole, customRoleId?: string}
  role            OrganizationUserRole
  requestedBy     String?
  requestedByUser User?                @relation(fields: [requestedBy], references: [id])
  subscriptionId  String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @default(now()) @updatedAt

  @@index([organizationId])
  @@index([requestedBy])
}

enum EvaluationExecutionMode {
  ON_MESSAGE
  AS_GUARDRAIL
  MANUALLY
}

model Monitor {
  id                String                  @id @default(nanoid())
  projectId         String
  project           Project                 @relation(fields: [projectId], references: [id])
  experimentId      String?                 @unique
  experiment        Experiment?             @relation(fields: [experimentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  evaluatorId       String? // Reference to saved Evaluator (new monitors)
  evaluator         Evaluator?              @relation(fields: [evaluatorId], references: [id])
  checkType         String
  name              String
  slug              String
  executionMode     EvaluationExecutionMode @default(ON_MESSAGE)
  enabled           Boolean                 @default(true)
  preconditions     Json
  parameters        Json // Keep for backward compatibility, new monitors may have empty
  mappings          Json?
  sample            Float                   @default(1.0)
  level             String                  @default("trace") // "trace" or "thread" - evaluation level
  threadIdleTimeout Int? // Seconds to wait after last message before evaluating thread. null = disabled (evaluate on every message)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @default(now()) @updatedAt

  @@unique([projectId, slug])
  @@index([projectId])
  @@index([evaluatorId])
}

enum CostType {
  TRACE_CHECK
  GUARDRAIL
  CLUSTERING
  BATCH_EVALUATION
}

enum CostReferenceType {
  CHECK
  TRACE
  PROJECT
  BATCH
}

model Cost {
  id            String            @id @default(nanoid())
  projectId     String
  project       Project           @relation(fields: [projectId], references: [id])
  costType      CostType
  costName      String?
  referenceType CostReferenceType
  referenceId   String
  amount        Float
  currency      String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @default(now()) @updatedAt
  extraInfo     Json?

  @@index([referenceType, referenceId])
  @@index([costType])
  @@index([projectId])
  @@index([projectId, createdAt])
}

model Topic {
  id        String  @id @default(nanoid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  name      String
  parentId  String?
  parent    Topic?  @relation("Subtopics", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  subtopics Topic[] @relation("Subtopics")

  embeddings_model       String
  centroid               Json
  p95Distance            Float
  automaticallyGenerated Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([parentId])
  @@index([projectId])
}

model Dataset {
  id               String            @id @default(nanoid())
  projectId        String
  project          Project           @relation(fields: [projectId], references: [id])
  name             String
  slug             String
  columnTypes      Json
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now()) @updatedAt
  archivedAt       DateTime?
  datasetRecords   DatasetRecord[]
  batchEvaluations BatchEvaluation[]
  mapping          Json?
  useS3            Boolean           @default(false)
  s3RecordCount    Int?

  @@unique([projectId, slug])
}

model DatasetRecord {
  id        String   @id @default(nanoid())
  datasetId String
  dataset   Dataset  @relation(fields: [datasetId], references: [id])
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  entry     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([datasetId])
  @@index([projectId])
  @@index([createdAt])
}

model Dashboard {
  id        String        @id @default(nanoid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id])
  name      String
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @default(now()) @updatedAt
  graphs    CustomGraph[]

  @@index([projectId])
  @@index([projectId, order])
  @@map("Dashboard")
}

model SavedView {
  id        String   @id @default(nanoid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  name      String
  filters   Json     @default("{}")
  query     String?
  period    Json?
  order     Int      @default(0)
  /// Discriminator for the two storage shapes that share this table:
  ///   - "v1-traces-filter" (default) — legacy /messages page filter map saved views
  ///   - "v2-traces-lens"             — new traces v2 lens configs (columns, addons, grouping, sort, filterText) encoded inside `filters` JSON
  /// Each client filters by its own kind on read so neither sees the other's rows.
  kind      String   @default("v1-traces-filter")
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([projectId])
  @@index([projectId, order])
  @@index([userId])
  @@index([projectId, kind, order])
}

model CustomGraph {
  id        String   @id @default(nanoid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  name      String
  graph     Json
  filters   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Report page relationship
  dashboardId String?
  dashboard   Dashboard? @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  // Grid positioning (2-column grid)
  gridColumn  Int           @default(0)
  gridRow     Int           @default(0)
  colSpan     Int           @default(1)
  rowSpan     Int           @default(1)
  trigger     Trigger?
  TriggerSent TriggerSent[]

  @@index([projectId])
  @@index([dashboardId])
}

model BatchEvaluation {
  id           String     @id @default(nanoid())
  experimentId String
  experiment   Experiment @relation(fields: [experimentId], references: [id])
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id])
  data         Json       @default("{}")
  status       String
  score        Float
  label        String?
  passed       Boolean
  details      String
  cost         Float
  datasetSlug  String
  datasetId    String
  dataset      Dataset    @relation(fields: [datasetId], references: [id])
  evaluation   String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now()) @updatedAt

  @@unique([id])
  @@index([projectId])
  @@index([datasetId])
  @@index([experimentId])
}

enum TriggerAction {
  SEND_EMAIL
  ADD_TO_DATASET
  ADD_TO_ANNOTATION_QUEUE
  SEND_SLACK_MESSAGE
}

enum AlertType {
  CRITICAL
  WARNING
  INFO
}

model Trigger {
  id            String        @id @default(nanoid())
  name          String
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id])
  action        TriggerAction
  actionParams  Json
  filters       Json
  lastRunAt     Float         @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt
  active        Boolean       @default(true)
  message       String?
  deleted       Boolean       @default(false)
  alertType     AlertType?
  // Customer-authored Liquid notification templates (see ADR-026). NULL on any
  // column means "render with the framework default", so existing triggers are
  // unchanged. slackTemplateType discriminates 'string' | 'block_kit'.
  slackTemplateType    String?
  slackTemplate        String?
  emailSubjectTemplate String?
  emailBodyTemplate    String?
  // Per-trigger digest cadence; see ADR-025. Ignored for persist actions.
  // Values: 'immediate' | '5min_digest' | '15min_digest' | 'hourly_digest'.
  notificationCadence  String        @default("immediate")
  TriggerSent   TriggerSent[]
  customGraphId String?       @unique
  customGraph   CustomGraph?  @relation(fields: [customGraphId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum ExperimentType {
  DSPY
  BATCH_EVALUATION
  BATCH_EVALUATION_V2
  EVALUATIONS_V3
}

model Experiment {
  id               String            @id @default(nanoid())
  name             String?
  type             ExperimentType
  slug             String
  projectId        String
  project          Project           @relation(fields: [projectId], references: [id])
  workflowId       String?
  workflow         Workflow?         @relation(fields: [workflowId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now()) @updatedAt
  batchEvaluations BatchEvaluation[]
  workbenchState   Json?
  monitor          Monitor?

  @@unique([projectId, slug])
  @@index([projectId])
  @@index([workflowId])
}

model Annotation {
  id             String   @id @default(nanoid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id])
  traceId        String
  comment        String?
  isThumbsUp     Boolean?
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  email          String?
  scoreOptions   Json?
  expectedOutput String?

  @@index([projectId])
  @@index([traceId])
  @@index([userId])
  @@index([projectId, traceId])
}

// ModelProvider — org-scoped, multi-scope provider configuration.
//
// Iter 110: absorbed GatewayProviderCredential entirely. The gateway
// data-plane reads its provider chain directly from ModelProvider +
// RoutingPolicy.modelProviderIds. Multi-deployment (Azure regions,
// OpenAI base-url variants) ships as N MP rows with auto-suffixed
// names (iter 109 pattern) — no `slot` discriminator column anymore.
//
// Access via ModelProviderScope only. No `projectId` legacy pointer;
// reads filter by the caller's membership set against scope rows.
//
// "Advanced (Gateway)" tab in the drawer surfaces the rate-limit /
// extraHeaders / providerConfig / fallbackPriorityGlobal / health
// fields below — same fields that lived on GatewayProviderCredential
// pre-110, just collapsed onto the provider they always 1:1-bound.
model ModelProvider {
  id                     String   @id @default(nanoid())
  // Human-readable name (iter 109): one "OpenAI" by default, auto-
  // suffixed as "OpenAI 2" / "OpenAI 3" when duplicates coexist
  // under the same organization. Model selectors use this to group
  // options when multiple instances of the same provider are in
  // scope for a project.
  name                   String
  provider               String
  enabled                Boolean
  customKeys             Json?
  // Provider-side custom headers — appended on every request the
  // gateway routes through this MP. (Pre-110 this lived on GPC.)
  extraHeaders           Json?
  customModels           Json?
  customEmbeddingsModels Json?
  deploymentMapping      Json?

  // Gateway rate-limits (advanced). Optional caps applied per MP.
  rateLimitRpm           Int?
  rateLimitTpm           Int?
  rateLimitRpd           Int?

  // Per-MP credential rotation policy (gateway-only). v1 ships MANUAL
  // only; AUTO + external-secret-store integration are v1.1 scope.
  rotationPolicy         GatewayProviderRotationPolicy @default(MANUAL)

  // Provider-specific routing hints (e.g. bedrock region, azure
  // deployment override). Gateway applies on top of standard config.
  providerConfig         Json?

  // Fallback priority used when a VK has no RoutingPolicy. Lower =
  // tried first. Tiebreak by createdAt ASC. Deterministic across runs.
  fallbackPriorityGlobal Int?

  // Health / circuit breaker state written by the gateway.
  healthStatus           GatewayProviderHealthStatus @default(UNKNOWN)
  circuitOpenedAt        DateTime?
  lastHealthCheckAt      DateTime?

  disabledAt             DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @default(now()) @updatedAt
  scopes                 ModelProviderScope[]

  @@index([healthStatus])
  @@index([fallbackPriorityGlobal])
}

// Principal-style N-scope access (iter 109, ADR-016 follow-up): a
// single ModelProvider row can be visible to multiple organizations,
// teams, or projects. scopeType is one of "ORGANIZATION" / "TEAM" /
// "PROJECT"; scopeId is the matching id of the scoping entity.
// Writing an entry requires the caller to hold the matching manage-
// permission on that entity (organization:manage, team:manage,
// project:manage). Reads filter by the caller's membership set.
// scopeType uses its own Postgres enum following the per-table
// convention (RoleBindingScopeType / GatewayBudgetScopeType / etc).
// See dev/docs/best_practices/scoped-resources.md.
enum ModelProviderScopeType {
    ORGANIZATION
    TEAM
    PROJECT
}

model ModelProviderScope {
  id              String                 @id @default(nanoid())
  modelProviderId String
  modelProvider   ModelProvider          @relation(fields: [modelProviderId], references: [id], onDelete: Cascade)
  scopeType       ModelProviderScopeType
  scopeId         String
  createdAt       DateTime               @default(now())

  @@unique([modelProviderId, scopeType, scopeId])
  @@index([scopeType, scopeId])
  @@index([modelProviderId])
}

// ModelDefault is the source of truth for "which model does {feature, role}
// resolve to at {scope}" once the resolver lands in B3.1. A null featureKey
// is the role-level default for that scope; a populated featureKey is a
// per-feature override. See specs/model-providers/model-resolver-and-registry.feature.
//
// The two partial unique indexes encode the (NULL = role-level) semantics
// since Postgres treats NULLs as distinct in a single composite unique.
// They live in the migration alongside the table itself — Prisma can't
// express partial indexes in schema.prisma.
// scopeType uses its own Postgres enum — same per-table convention as
// ModelProviderScopeType. See dev/docs/best_practices/scoped-resources.md.
enum ModelDefaultScopeType {
    ORGANIZATION
    TEAM
    PROJECT
}

// ModelDefaultConfig is one CSS-style cascading policy. The JSON `config`
// payload maps role names (DEFAULT / FAST / EMBEDDINGS) and feature keys
// (prompt.create_default, traces.ai_search, …) to a model id. Absence of
// a key means "inherit from the next scope up" — there is no explicit
// "inherit" sentinel in storage. See
// specs/model-providers/model-default-config-cascade.feature.
//
// One config attaches to N scopes via ModelDefaultConfigScope (same n:n
// pattern as ModelProvider + ModelProviderScope from iter 109), so one
// "Production models" policy can apply to Team A + Team B + Project X
// with one row of state.
//
// On read the resolver walks PROJECT → TEAM → ORG; within a tier the
// newest createdAt config that has the key wins. Lower-tier configs
// always beat higher-tier ones even if higher tier was created later
// (CSS specificity wins over recency across tiers).
model ModelDefaultConfig {
    id        String                    @id @default(nanoid())
    config    Json
    authorId  String?
    createdAt DateTime                  @default(now())
    updatedAt DateTime                  @updatedAt
    scopes    ModelDefaultConfigScope[]
}

// Join table binding a ModelDefaultConfig to a (scopeType, scopeId).
// One config can have many scope attachments; one scope can have many
// configs (resolver tiebreaks by createdAt DESC).
model ModelDefaultConfigScope {
    id        String                @id @default(nanoid())
    configId  String
    config    ModelDefaultConfig    @relation(fields: [configId], references: [id], onDelete: Cascade)
    scopeType ModelDefaultScopeType
    scopeId   String
    createdAt DateTime              @default(now())

    @@unique([configId, scopeType, scopeId])
    @@index([scopeType, scopeId])
    @@index([configId])
}

