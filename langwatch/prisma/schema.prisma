  roleBindings   RoleBinding[]     @relation("GroupBindings")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @default(now()) @updatedAt

  @@unique([organizationId, slug])
  @@unique([organizationId, externalId])
  @@index([organizationId])
}

model GroupMembership {
  userId    String
  groupId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, groupId])
  @@index([userId])
  @@index([groupId])
}

model RoleBinding {
  id             String       @id @default(nanoid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Principal — exactly one must be set
  userId   String?
  user     User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId  String?
  group    Group?   @relation("GroupBindings", fields: [groupId], references: [id], onDelete: Cascade)
  apiKeyId String?
  apiKey   ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: Restrict)

  // Role — built-in named role or custom
  role         TeamUserRole
  customRoleId String?
  customRole   CustomRole?  @relation(fields: [customRoleId], references: [id])

  // Scope — scopeType + scopeId identify the resource
  scopeType RoleBindingScopeType
  scopeId   String // orgId, teamId, or projectId depending on scopeType

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Uniqueness is enforced by six partial unique indexes defined in migrations:
  //   • user + group (built-in and custom) — 20260410120000_fix_role_binding_unique_custom_role
  //   • apiKey (built-in and custom) — 20260414222341_add_personal_access_tokens
  // Prisma does not support partial indexes natively, so there is no @@unique here.
