// AuditLog is the unified governance ledger. Both gateway-driven mutations
// (VK/budget/provider-binding/cache-rule via the 4 gateway services) and
// platform-driven actions (tRPC mutations via auditLogMutations middleware)
// write here. There is no separate GatewayAuditLog table — see migration
// 20260425000000_consolidate_gateway_audit_into_audit_log.
//
// Two write shapes coexist on the same table:
//   * Platform shape  — `args` + `metadata` + `error` carry the call-site
//     context. `targetKind`, `targetId`, `before`, `after` stay null.
//   * Gateway shape   — `targetKind`, `targetId`, `before`, `after` carry
//     resource identity + diff. `args` / `metadata` / `error` stay null.
// The /settings/audit-log page renders both via a `source` field computed
// from the presence of `targetKind` (gateway = purple badge, platform = grey).
model AuditLog {
    id             String   @id @default(cuid())
    createdAt      DateTime @default(now())
    userId         String?
    projectId      String?
    organizationId String?
    action         String
    args           Json?
    error          String?
    ipAddress      String?
    userAgent      String?
    metadata       Json?

    // Gateway-shape governance fields (see model docstring above).
    targetKind     String?
    targetId       String?
    before         Json?
    after          Json?

    @@index([createdAt])
    @@index([userId])
    @@index([projectId])
    @@index([action])
    @@index([ipAddress])
    @@index([organizationId, createdAt])
    @@index([targetKind, targetId])
}

