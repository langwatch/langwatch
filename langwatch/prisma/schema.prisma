// ============================================================================
// AI Gateway
//
// Wire-shape aligned with specs/ai-gateway/_shared/contract.md (v0.1).
//
// - VirtualKey: project-scoped LangWatch-issued credential consumed by the
//   Go gateway. Secret is argon2id-hashed; only the display prefix is kept.
// - GatewayProviderCredential: a thin binding over an existing ModelProvider
//   row, carrying gateway-only settings (rate limits, rotation policy,
//   gateway-only extra headers). Never duplicates the raw API key.
// - VirtualKeyProviderCredential: the ordered fallback chain linking a VK
//   to N provider-credential bindings.
// - GatewayBudget: hierarchical budgets (org / team / project / vk /
//   principal) with calendar resets and block|warn semantics.
// - GatewayBudgetLedger: idempotent spend ledger keyed by
//   gateway_request_id (outbox pattern — writes from the Go gateway).
// - GatewayChangeEvent: monotonically-increasing revision feed consumed by
//   the gateway's long-poll `/internal/gateway/changes?since=N` endpoint.
// - AuditLog (top of file): unified actor/action/before/after audit for
//   every gateway-surface mutation alongside platform mutations.
// ============================================================================


enum VirtualKeyStatus {
  ACTIVE
  REVOKED
}

// Rotation policy for gateway provider credentials.
// v1 ships MANUAL only — operators rotate via the Rotate button in
// the UI or by calling POST /providers/:id/rotate. Scheduled rotation
// (AUTO) and external-secret-store integration (Vault / AWS Secrets
// Manager / GCP Secret Manager) are v1.1 scope; the enum will grow
// back when those are implemented. Shipping stubbed options here
// would mislead operators into thinking they're configuring a feature
// that silently does nothing. See iter 56 dogfood feedback.
enum GatewayProviderRotationPolicy {
  MANUAL
}

enum GatewayProviderHealthStatus {
  UNKNOWN
  HEALTHY
  DEGRADED
  CIRCUIT_OPEN
}

enum GatewayBudgetScopeType {
  ORGANIZATION
  TEAM
  PROJECT
  VIRTUAL_KEY
  PRINCIPAL
}

enum GatewayBudgetWindow {
  MINUTE
  HOUR
  DAY
  WEEK
  MONTH
  TOTAL
}

enum GatewayBudgetBreachAction {
  BLOCK
  WARN
}

enum GatewayBudgetLedgerStatus {
  SUCCESS
  PROVIDER_ERROR
  BLOCKED_BY_GUARDRAIL
  CANCELLED
}

enum GatewayChangeEventKind {
  VK_CREATED
  VK_CONFIG_UPDATED
  VK_REVOKED
  VK_ROTATED
  BUDGET_CREATED
  BUDGET_UPDATED
  BUDGET_DELETED
  MODEL_PROVIDER_UPDATED
  CACHE_RULE_CREATED
  CACHE_RULE_UPDATED
  CACHE_RULE_DELETED
}

// Gateway audit action codes — kept as a TypeScript const union in
// langwatch/src/server/gateway/auditLog.repository.ts (no Prisma enum
// because gateway rows now write to the shared `AuditLog` table whose
// `action` column is a free-form String).
//
// enum GatewayAuditAction { ... } — removed in migration
// 20260425000000_consolidate_gateway_audit_into_audit_log.

enum GatewayCacheRuleMode {
  RESPECT
  FORCE
  DISABLE
}

// VirtualKey — org-scoped, multi-scope routing key for the AI Gateway.
//
// Iter 110 refactor: collapsed VirtualKey -> GatewayProviderCredential
// binding entirely (per rchaves). Provider-routing knobs (rpm/tpm/headers/
// providerConfig/etc) moved onto ModelProvider's "Advanced (Gateway)" tab.
// Per-VK chain ordering moved onto RoutingPolicy.modelProviderIds. Per-VK
// header overrides removed (use a sibling ModelProvider row for that 1%).
//
// Scoping mirrors ModelProviderScope (iter 109): a single VirtualKey row
// is reachable from multiple scopes (org / team / project) via
// VirtualKeyScope rows. No `projectId` column — multitenant key is
// `organizationId` (mandatory, matches the new dbMultiTenancyProtection
// invariant).
//
// `principalUserId` stays orthogonal to scopes: it marks "who owns this
// personal VK" for trace attribution + admin-view filtering, not "where
// can this route". A personal VK is a VK with `principalUserId` set; its
// scopes (typically ORGANIZATION) determine the routing reach.
//
// No DB-level FK constraints (codebase convention) — string columns +
// indexes; integrity enforced at service layer.
model VirtualKey {
  id             String @id @default(nanoid())
  organizationId String

  name        String
  description String?
  status      VirtualKeyStatus @default(ACTIVE)

  // Credential material. Full secret format:
  //   vk-lw-<26-char-crockford-ulid>  (32 chars total)
  // Only the hashed form and a short display prefix are kept after
  // creation. The full secret is shown exactly once.
  hashedSecret  String // argon2id(secret + server pepper)
  displayPrefix String // e.g. "vk-lw-01HZX9"

  // Principal user the VK is attributed to for trace ownership + audit.
  // Set for personal VKs minted via `langwatch login --device`; null for
  // org-/team-/project-owned VKs minted by an admin.
  principalUserId String?
  principalUser   User?   @relation("PrincipalScopedVirtualKeys", fields: [principalUserId], references: [id], onDelete: SetNull)

  // Slim config blob — per-key state only. The "gateway-config bundle"
  // that the gateway reads via /internal/gateway/config/:vk_id is now
  // materialised on-read from the scope graph (eligible ModelProviders
  // resolved by VirtualKeyScope + the linked RoutingPolicy ordering),
  // not pre-baked into this field. Allowed keys: `model_aliases`,
  // `models_allowed`. Everything else (rate_limits, fallback, cache,
  // guardrails) moved to ModelProvider (Advanced tab) or RoutingPolicy.
  config Json @default("{}")

  // Revision — every mutation bumps this; gateway uses it to skip config
  // fetches that would be no-ops.
  revision BigInt @default(0)

  // Rotation bookkeeping. When rotated in place, the previous secret stays
  // valid for 24h via `previousHashedSecret` + `previousSecretValidUntil`.
  previousHashedSecret     String?
  previousSecretValidUntil DateTime?

  revokedAt   DateTime?
  revokedById String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  createdById String
  lastUsedAt  DateTime?

  scopes        VirtualKeyScope[]
  budgets       GatewayBudget[]       @relation("VirtualKeyScopedGatewayBudgets")
  ledgerEntries GatewayBudgetLedger[]

  // Optional RoutingPolicy reference. When set, gateway pulls
  // ordered ModelProvider chain from the policy + the policy's
  // modelAliases + policyRules. When null, the materialiser falls
  // back to ordering eligible ModelProviders by
  // `fallbackPriorityGlobal` (asc) then `createdAt` (asc) —
  // deterministic across runs and Go-side parsers.
  routingPolicyId String?
  routingPolicy   RoutingPolicy? @relation("VirtualKeyRoutingPolicy", fields: [routingPolicyId], references: [id], onDelete: SetNull)

  @@unique([hashedSecret])
  @@index([organizationId])
  @@index([displayPrefix])
  @@index([status])
  @@index([principalUserId])
  @@index([revision])
  @@index([routingPolicyId])
}

// VirtualKeyScope — N-scope access for VirtualKey, mirrors
// ModelProviderScope exactly. A single VK row is reachable from any
// scope it has a matching entry for. Writing requires the caller to
// hold the matching `virtualKeys:manage` permission at that scope.
//
// Scope-cascade resolution (read-time): a VK at PROJECT:P sees
// ModelProviders scoped at PROJECT:P, TEAM:P.team, or
// ORGANIZATION:vk.organizationId. A VK at ORGANIZATION sees only
// ORGANIZATION-scoped MPs (no leakage down). Same upward-walking
// intersection rule used by ModelDefaultConfig.
enum VirtualKeyScopeType {
  ORGANIZATION
  TEAM
  PROJECT
}

model VirtualKeyScope {
  id           String              @id @default(nanoid())
  virtualKeyId String
  virtualKey   VirtualKey          @relation(fields: [virtualKeyId], references: [id], onDelete: Cascade)
  scopeType    VirtualKeyScopeType
  scopeId      String
  createdAt    DateTime            @default(now())

  @@unique([virtualKeyId, scopeType, scopeId])
  @@index([scopeType, scopeId])
  @@index([virtualKeyId])
}

// ---------------------------------------------------------------------------
// RoutingPolicy — admin-defined routing template referenced by VirtualKey.
//
// A policy answers two gateway questions in one place:
//   1. Which provider credentials are eligible for a given request?
//   2. In what order / by what strategy do we pick among eligible providers?
//
// Decoupling these from the VK itself lets the admin publish (e.g.)
// `developer-default` once and have every personal VK in the org inherit
// the same routing semantics — no per-key configuration needed.
//
// Scoping mirrors GatewayBudget: an org-scoped policy applies to any VK
// in the org; a team-scoped policy applies to VKs whose project lives in
// that team; a project-scoped policy applies only to VKs in that project.
// `isDefault=true` (one per scope tier) makes the policy auto-apply when
// `virtualKey.issuePersonal` is called without an explicit policyId.
// ---------------------------------------------------------------------------
// RoutingPolicyScopeType — normalised from the legacy String 'scope'
// column to a proper Postgres enum, matching the per-table convention
// used by ModelProviderScopeType / GatewayBudgetScopeType / etc.
enum RoutingPolicyScopeType {
  ORGANIZATION
  TEAM
  PROJECT
}

model RoutingPolicy {
  id             String       @id @default(nanoid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  description String?

  // Ordered list of ModelProvider.id values (post-iter-110: GPC merged
  // into MP, the chain refers to MPs directly). JSON for shape
  // flexibility; gateway materialises into provider chain at request
  // time. Order = try-first when strategy = 'priority'.
  modelProviderIds Json @default("[]")

  // Optional model allowlist (JSON array of glob patterns).
  // null/empty = "all models the eligible providers can serve".
  modelAllowlist Json?

  // Model name rewrites applied before dispatch. Shape:
  //   { "gpt-4o": "gpt-4o-mini", "claude": "anthropic/claude-haiku-4-5" }
  // Hoisted from per-VK config (iter 110) onto the RoutingPolicy so a
  // single policy edit updates every VK linked to it. Empty object = no
  // rewrites.
  modelAliases Json @default("{}")

  // Provider-agnostic policy rules — deny/allow lists per dimension.
  // Shape: { tools: { deny: string[]; allow: string[] | null }, mcp: {...}, urls: {...}, models: {...} }
  // Hoisted from per-VK config (iter 110). Enforced pre-provider-dispatch.
  policyRules Json @default("{}")

  // Routing strategy applied across the model-eligible subset.
  //   'priority'    — try modelProviderIds in order (default)
  //   'cost'        — pick lowest unit cost first
  //   'latency'     — pick fastest healthy provider
  //   'round_robin' — distribute evenly
  strategy String @default("priority")

  isDefault Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  createdById String?
  createdBy   User?    @relation("RoutingPolicyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?    @relation("RoutingPolicyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  // VKs that reference this policy. relationMode="prisma" so no SQL FK
  // is emitted; this exists purely to let the materialiser hydrate the
  // policy via `include: { routingPolicy: ... }` on the VK query.
  virtualKeys VirtualKey[] @relation("VirtualKeyRoutingPolicy")

  // Multi-scope assignments. A policy is selectable from any scope row
  // (union semantics). RoutingPolicyScope is the only source of truth
  // for which scopes a policy is reachable from.
  scopes RoutingPolicyScope[]

  @@index([organizationId])
}

// RoutingPolicyScope — N-scope access for RoutingPolicy. Mirrors
// VirtualKeyScope + ModelProviderScope exactly. A single RP row is
// reachable from any scope it has a matching entry for.
model RoutingPolicyScope {
  id              String                 @id @default(nanoid())
  routingPolicyId String
  routingPolicy   RoutingPolicy          @relation(fields: [routingPolicyId], references: [id], onDelete: Cascade)
  scopeType       RoutingPolicyScopeType
  scopeId         String
  createdAt       DateTime               @default(now())

  @@unique([routingPolicyId, scopeType, scopeId])
  @@index([scopeType, scopeId])
  @@index([routingPolicyId])
}

// ---------------------------------------------------------------------------
// GatewayGuardrail — project-scoped Evaluator binding the gateway enforces
// on inbound + outbound traffic per VK opt-in.
//
// Lifted from per-VK config (iter 110: vk.config.guardrails) so a project
// admin can author one guardrail and attach it to N VKs by reference,
// instead of duplicating the evaluator binding + failure mode on every VK.
// VKs opt in via vk.config.guardrailAttachments[] of
//   { direction, guardrailIds[] }
// tuples; cross-project attach is rejected at write time.
//
// Project-scoped only (for now) per rchaves: a single non-null projectId
// column, NO scope join table. Widening to team / org guardrails later
// drops the column to nullable + adds a GatewayGuardrailScope join in a
// separate migration. The single-column shape is intentional — keeps the
// current constraint enforced at schema level, not at resolver level.
//
// Spec: specs/ai-gateway/governance/guardrails-project-scope.feature
// ---------------------------------------------------------------------------
enum GatewayGuardrailDirection {
  PRE
  POST
  STREAM_CHUNK
}

enum GatewayGuardrailFailureMode {
  FAIL_OPEN
  FAIL_CLOSED
}

model GatewayGuardrail {
  id          String                      @id @default(nanoid())
  projectId   String
  project     Project                     @relation("ProjectGatewayGuardrails", fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  evaluatorId String
  evaluator   Evaluator                   @relation("EvaluatorGatewayGuardrails", fields: [evaluatorId], references: [id], onDelete: Restrict)
  direction   GatewayGuardrailDirection
  failureMode GatewayGuardrailFailureMode @default(FAIL_CLOSED)

  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  createdById String?
  createdBy   User?     @relation("GatewayGuardrailCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?     @relation("GatewayGuardrailUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([evaluatorId])
  @@index([projectId, archivedAt])
}

/// Per-platform fleet configuration that connects a closed SaaS
/// product's audit / OTel / S3 stream to LangWatch's Activity
/// Monitor (cf. specs/ai-gateway/governance/activity-monitor.feature
/// + ingestion-sources.feature, docs/ai-gateway/governance/architecture.md).
///
/// One IngestionSource = one upstream fleet (e.g. "Miro Cowork",
/// "Acme Workato production"). The runtime ingests events on whatever
/// cadence the source supports — push for OTel/webhook/S3 (Tier C/D),
/// pull for poll-based admin APIs (Tier C). Per-source-type adapters
/// normalise platform-specific shapes into OCSF + AOS before they
/// land in trace_summaries with SourceType + SourceId tags.
model IngestionSource {
  id             String       @id @default(nanoid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Optional team-scope. null = org-wide.
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  /// 'otel_generic' | 'claude_cowork' | 'workato' | 'copilot_studio' |
  /// 'openai_compliance' | 'claude_compliance' | 's3_custom' (extensible).
  /// String not enum so adapters can be added without migrations — the
  /// supported set lives in code (activity-monitor adapter registry).
  sourceType String

  /// Human-friendly label for the admin UI. Unique per-org so two
  /// "Cowork" sources can coexist with different names.
  name        String
  description String?

  /// HMAC bearer token the upstream operator pastes into the platform
  /// (or LangWatch sends in pull mode). Stored encrypted at rest via
  /// the same pepper-derived KEK as VirtualKey secrets. Auto-generated
  /// on create, rotatable via the admin UI with a 24h grace window.
  ingestSecretHash String

  /// Per-source-type configuration. Shape is platform-specific:
  ///   - otel_generic: { allowedSourceTypeLabel?: string }
  ///   - claude_cowork: { workspaceId: string }
  ///   - workato: { sharedSecretLastFour: string }
  ///   - copilot_studio: { tenantId, clientId, clientSecretHash, pollEverySec }
  ///   - openai_compliance: { bucket, prefix, roleArn, pollEverySec }
  ///   - claude_compliance: { workspaceApiKeyHash, pollEverySec }
  ///   - s3_custom: { bucket, prefix, roleArn, parserDsl, pollEverySec }
  parserConfig Json @default("{}")

  /// For pull-based sources, persisted between polls so the next poll
  /// resumes where the last left off (timestamp / cursor / file marker).
  pollerCursor Json?

  /// Phase 10 — number of consecutive errors observed by the puller
  /// worker. Reset to 0 on a successful run. Drives admin-UI banners
  /// ("Microsoft authentication failed — re-authorize") + back-off
  /// scheduling when the source has been broken for a while.
  /// Spec: specs/ai-governance/puller-framework/puller-adapter-contract.feature
  errorCount Int @default(0)

  /// Phase 10 — cron schedule for pull-mode sources. Validated by the
  /// adapter's pullConfig schema; mirrored here for fast worker
  /// dispatch. Null for push-mode sources.
  pullSchedule String?

  /// Status flag. 'active' (default), 'disabled' (admin paused), or
  /// 'awaiting_first_event' (created but never received).
  status String @default("awaiting_first_event")

  /// Per-origin retention class applied to every span/log emitted by
  /// this source's events when they land in the unified observability
  /// store (recorded_spans / log_records). Drives the CH TTL policy.
  /// Values:
  ///   - "thirty_days": operational debugging window (default)
  ///   - "one_year":    compliance baseline (SOC2 / ISO 27001 / EU AI Act)
  ///   - "seven_years": long-form audit (regulated industry)
  /// Org plan ceiling enforced at the composer / API layer.
  /// Stored as string for extensibility — the canonical set lives in
  /// code (governance retention policy registry).
  /// Spec: specs/ai-gateway/governance/retention.feature
  retentionClass String @default("thirty_days")

  /// Last event timestamp observed (any direction). Surfaces in the
  /// admin UI as "last event 2 minutes ago".
  lastEventAt DateTime?

  archivedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  createdById String?
  createdBy   User?    @relation("IngestionSourceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([teamId])
  @@index([sourceType])
}

/// Admin-defined anomaly detection rule. Evaluated server-side at
/// ingest time (Option C — not in this slice yet) against
/// gateway_activity_events. When triggered, an alert is dispatched
/// to the destinations configured on the rule (Slack / SIEM / webhook
/// / PagerDuty / email).
///
/// This is a configuration entity — the actual rule evaluation +
/// alert state lives in a future ClickHouse table
/// (gateway_anomaly_alerts) and a server-side worker. Spec:
/// specs/ai-gateway/governance/anomaly-rules.feature
/// (Alexis lane B C-UI; mocked-v0 today, real persistence is THIS slice).
model AnomalyRule {
  id             String       @id @default(nanoid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// 'organization' | 'team' | 'project' | 'source_type' | 'source'.
  /// String not enum so new scopes ship without migrations.
  scope   String
  /// Org id / team id / project id / source-type string / source id
  /// — narrows what the rule applies to.
  scopeId String

  name        String
  description String?

  /// 'critical' | 'warning' | 'info'. Drives default destination
  /// routing (e.g. critical → PagerDuty, warning → Slack only).
  severity String

  /// Extensible rule taxonomy: 'spend_spike' | 'rate_limit' |
  /// 'tool_mismatch' | 'after_hours' | 'unusual_model' | 'pii_leak'
  /// | 'custom'. New types ship without migrations — evaluator
  /// picks a per-type implementation from a code registry.
  ruleType String

  /// Per-rule-type threshold shape. Examples:
  ///   spend_spike: { windowSec, ratioVsBaseline, minBaselineUsd }
  ///   rate_limit: { windowSec, requestsThreshold }
  ///   after_hours: { startHour, endHour, timezone, requestsThreshold }
  thresholdConfig Json @default("{}")

  /// Alert routing per destination. Shape:
  ///   { slack?: { channelId }, siem?: { endpointUrl, authHeader },
  ///     webhook?: { url, authHeader }, pagerduty?: { routingKey },
  ///     email?: { to: string[] } }
  /// Empty map = use org defaults (when defaults exist; today no-op).
  destinationConfig Json @default("{}")

  /// 'active' (default — evaluator picks it up) | 'disabled' (admin
  /// paused; rule rows kept for audit). 'archived' uses archivedAt
  /// timestamp instead so we can filter `archivedAt IS NULL` cheaply.
  status String @default("active")

  archivedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  createdById String?
  createdBy   User?    @relation("AnomalyRuleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  alerts AnomalyAlert[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([scope, scopeId])
  @@index([ruleType])
  @@index([status])
}

/// Persisted anomaly detection. Inserted by the anomaly-detection
/// reactor (event-sourcing pipeline; modeled on PR #3351's
/// alertTrigger pattern) when a rule's threshold trips while
/// processing a freshly-arrived ActivityEventReceived event.
/// Read by api.activityMonitor.recentAnomalies for the admin dashboard.
///
/// Dedup: (ruleId, triggerWindowStart) — re-evaluating the same
/// window updates the existing row rather than creating a duplicate.
/// Acknowledgement / resolution are admin actions on the row.
///
/// Spec: specs/ai-gateway/governance/anomaly-detection.feature
model AnomalyAlert {
  id             String       @id @default(nanoid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ruleId         String
  rule           AnomalyRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  /// Denormalised from rule for fast WHERE filtering on the
  /// dashboard query (no join needed for the common path).
  severity String
  ruleName String
  ruleType String

  /// Window the trigger refers to (UTC).
  triggerWindowStart DateTime
  triggerWindowEnd   DateTime

  /// Numeric trigger context. Per-rule-type detail in `detail` JSONB.
  triggerSpendUsd   Decimal? @db.Decimal(18, 6)
  triggerEventCount Int?

  /// Per-rule-type extra context: {topActors: [...], baseline: ...,
  /// observed: ..., timezone: ..., etc}.
  detail Json @default("{}")

  /// 'open' | 'acknowledged' | 'resolved'.
  state String @default("open")

  /// Per-destination dispatch outcome:
  ///   { webhook: { lastAttemptIso, lastError?, attemptCount, statusCode? },
  ///     slack: ..., pagerduty: ..., siem: ..., email: ... }
  destinationStatus Json @default("{}")

  detectedAt     DateTime  @default(now())
  acknowledgedAt DateTime?
  resolvedAt     DateTime?

  @@unique([ruleId, triggerWindowStart])
  @@index([organizationId, detectedAt])
  @@index([ruleId])
  @@index([state])
}

/// Org-scoped catalog of AI tools surfaced on the personal home portal
/// (/me) and managed by org admins at /settings/governance/tool-catalog.
///
/// Three first-class tile types via `type` discriminator:
///   - "coding_assistant" — click expands to setup helper (e.g. `langwatch claude`)
///   - "model_provider"   — click expands to inline personal-VK creation
///   - "external_tool"    — click expands to admin-attached markdown + external link
///
/// Scoping: organization-default entries can be OVERRIDDEN at the team
/// tier (same `slug` + `scope=team` + matching `scopeId`) so admins can
/// hide or re-skin a globally-listed tool for a specific team. The
/// user-facing `list` endpoint resolves this hierarchy at read time.
///
/// `config` is a discriminated JSON union per `type`:
///   coding_assistant: { setupCommand, setupDocsUrl, helperText? }
///   model_provider:   { providerKey, suggestedRoutingPolicyId?, defaultLabel?, projectSuggestionText? }
///   external_tool:    { descriptionMarkdown, linkUrl, ctaLabel? }
///
/// Spec: specs/ai-governance/personal-portal/tool-catalog-*.feature
model AiToolEntry {
  id             String       @id @default(nanoid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// "organization" | "team". String not enum so new scopes ship
  /// without migrations.
  scope   String
  /// organizationId or teamId, narrowing what scope this entry applies
  /// to. Always equals organizationId when scope=organization.
  scopeId String

  /// "coding_assistant" | "model_provider" | "external_tool".
  /// Discriminator drives the per-tile UX shape and validates
  /// the `config` JSON column at the app layer.
  type String

  displayName String

  /// Stable slug for team-overrides-org resolution (a team-scoped
  /// entry with the same slug as an org-scoped one hides the org
  /// default for users in that team). Server-owned: generated from
  /// displayName + nanoid(6) on create, immutable on update.
  slug String

  /// @deprecated Use `iconAsset` instead. Kept for back-compat with
  /// pre-refactor rows; new writes should populate iconAsset.
  iconKey String?

  /// Icon source — single column, prefix-discriminated:
  ///   "preset:claude_code" / "preset:codex" / ...   (built-in)
  ///   "data:image/svg+xml;base64,..."               (admin-uploaded)
  ///   null                                          → fall back to
  ///                                                   type-default in UI
  iconAsset String? @db.Text

  /// Admin-curated sort within the user-facing portal grid.
  order Int @default(0)

  /// When false the entry is hidden from the user-facing list but
  /// remains in the admin list (so admins can re-enable without
  /// losing per-entry config). Disabled is "soft-hide", archived is
  /// "soft-delete" (preserves audit trail + scope binding history).
  enabled Boolean @default(true)

  /// Per-type config JSON. Validated via zod discriminated union
  /// at the service layer (see AiToolEntryService).
  config Json @default("{}")

  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  createdById String?
  updatedById String?

  /// Multi-team scope. Empty = org-wide (visible to every member).
  /// Non-empty = restricted to those teams. Replaces the legacy
  /// scope+scopeId pair, which stays populated for back-compat
  /// during the rollout (scope='organization' when teams is empty,
  /// scope='team' with scopeId=teams[0] when teams has one row;
  /// undefined for >1 — readers should prefer this relation).
  teams AiToolEntryTeam[]

  @@index([organizationId, scope, scopeId])
  @@index([organizationId, enabled, archivedAt])
  @@index([organizationId, type])
}

/// Per-team scope binding for AiToolEntry. Empty set = org-wide.
/// Non-empty = entry visible only to members of those teams.
model AiToolEntryTeam {
  id      String      @id @default(nanoid())
  entryId String
  teamId  String
  entry   AiToolEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  team    Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([entryId, teamId])
  @@index([teamId])
}

/// Admin/platform-curated catalog row for upstream OTLP normalization.
/// Owns the OTTL transform that reshapes a specific upstream tool's
/// span shape into canonical gen_ai conventions. Users install via
/// UserIngestionBinding to land traces in their personal project.
///
/// `organizationId` NULL = platform-published default (always-visible
/// across every org). NOT NULL = org-authored (visible only within
/// that org). v1 ships only platform-published; org-authored authoring
/// UI lands v2 (the column ships now to avoid a future migration).
///
/// Spec: specs/ai-gateway/governance/ingestion-templates-catalog.feature
model IngestionTemplate {
  id             String        @id @default(nanoid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Stable slug — unique within (organizationId, slug) scope. Generated
  /// from displayName + nanoid(6) on create for org-authored; canonical
  /// values for platform-published (`claude_code` / `cursor` /
  /// `claude_cowork` / `raw_otlp_advanced`).
  slug String

  /// Mirrors the slug for v1 platform-published rows. Kept as a separate
  /// column so a future v2 may publish two templates that share an
  /// upstream sourceType (e.g. claude_code-personal vs claude_code-team)
  /// without a migration. String not enum — extensibility.
  sourceType String

  displayName String
  description String? @db.Text

  /// Icon source — single column, prefix-discriminated, mirrors
  /// AiToolEntry.iconAsset:
  ///   `preset:<kind>`                 (built-in slot)
  ///   `data:image/svg+xml;base64,…`   (admin-uploaded for org-authored)
  ///   null                            → fall back to slug-default in UI
  iconAsset String? @db.Text

  /// Discriminator for what (if any) extra credential metadata the
  /// install drawer captures from the user:
  ///   null              → otlp_token-only (drawer auto-issues binding
  ///                       token, no input form)
  ///   `static_api_key`  → drawer captures the user's upstream tool
  ///                       API key into UserIngestionBinding.encryptedCredential
  ///   `agent_id`        → drawer captures an agent identifier (e.g.
  ///                       Cursor agentId) into the same column
  /// String not enum so v2 shapes (oauth_redirect / s3_bucket) ship
  /// without a migration.
  credentialSchema String?

  /// Admin/platform-authored OTTL statements. Applied at receive time
  /// AFTER the receiver re-stamps the binding's authoritative principal
  /// + provenance keys (see `protectedTemplateAttributeKeys` 19-key
  /// closed list). Templates write canonical OTTL outputs (gen_ai.*,
  /// cost.usd, response.model) — they CANNOT write attribution or
  /// provenance keys; the receiver guard restores those post-OTTL.
  ottlRules String @default("") @db.Text

  /// True for the v1 platform-published default templates
  /// (organizationId IS NULL). Future org-authored rows write false.
  /// Drives the admin UI "READ-ONLY view + Request a custom template"
  /// surface — admins consume + opt-out only in v1.
  platformPublished Boolean @default(false)

  /// Admin/platform enable. False = hidden from /me catalog. Existing
  /// UserIngestionBindings continue to land traces; new installs are
  /// blocked.
  enabled Boolean @default(true)

  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  createdById String?
  updatedById String?

  bindings UserIngestionBinding[]

  @@unique([organizationId, slug])
  @@index([organizationId, archivedAt])
  @@index([sourceType])
}

/// User-managed binding from an IngestionTemplate to the user's personal
/// project. Holds the `ik-lw-<base32>` binding access token (hashed) the
/// user pastes into their upstream tool's OTLP exporter Bearer auth.
///
/// Cross-bind guard is service-layer (structural-impossibility): the
/// service input shape MUST NOT accept personalProjectId. Server resolves
/// from `getPersonalProjectForUser(userId)` at install time, so a caller
/// cannot bind to another user's project even with the right templateId.
///
/// Hard-cut rotation v1: `bindingAccessTokenHash` is replaced in-place
/// on rotate, no grace window. Receiver returns a structured 'binding
/// rejected' state surfaced as a /me Trace Ingest tile banner.
///
/// Spec: specs/ai-gateway/governance/user-ingestion-binding-lifecycle.feature
///       specs/ai-gateway/governance/template-cross-bind-guard.feature
model UserIngestionBinding {
  id String @id @default(nanoid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  templateId String
  template   IngestionTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)

  /// Server-resolved at install (NOT input-accepted). Always points at
  /// the user's personal Project (`Project.isPersonal=true` AND
  /// `Project.team.ownerUserId === userId`). Receiver re-verifies at
  /// auth time as defense-in-depth.
  personalProjectId String
  personalProject   Project @relation(fields: [personalProjectId], references: [id], onDelete: Cascade)

  /// Denormalised for tenancy index — equals
  /// `personalProject.team.organizationId`. Lets admin views query
  /// bindings within an org without a 2-table join.
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// SHA256 hex of the `ik-lw-<base32>` token. Receiver auth path:
  /// SHA256(incoming Bearer) → indexed lookup. Single source of truth
  /// for binding auth.
  bindingAccessTokenHash String @unique

  /// First 8 characters of the token, displayed in /me Trace Ingest tile
  /// for "is this the right token" recognition. Never used for auth.
  bindingAccessTokenPrefix String

  /// Optional credential metadata captured at install time when the
  /// template's credentialSchema is `static_api_key` or `agent_id`.
  /// NULL when credentialSchema is null (otlp_token-only templates).
  /// Encrypted at rest via the same pepper-derived KEK as VirtualKey
  /// secrets. NOT used for receiver auth.
  encryptedCredential Json?

  /// User-side toggle. False = receiver rejects bound traces; tile shows
  /// 'Binding disabled — re-enable to resume'.
  enabled Boolean @default(true)

  /// Last successful trace landed timestamp. Surfaces in /me as
  /// "last trace 2 minutes ago" + admin-side as "is this binding live".
  /// NOT a per-trace audit row (volume).
  lastSeenAt DateTime?

  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt

  @@unique([userId, templateId])
  @@index([organizationId, archivedAt])
  @@index([userId, archivedAt])
  @@index([templateId])
  @@index([personalProjectId])
}

// GatewayProviderCredential + VirtualKeyProviderCredential were both
// dropped in iter 110 (collapse-VK-binding refactor). Provider-routing
// knobs (rateLimitRpm/Tpm/Rpd, extraHeaders, providerConfig,
// fallbackPriorityGlobal, rotationPolicy, health-status / circuit
// state) live on `ModelProvider` directly; the order-of-providers
// ("which to try first") lives on `RoutingPolicy.modelProviderIds`.

model GatewayBudget {
  id             String                 @id @default(nanoid())
  organizationId String
  // Scope is identified by (scopeType, scopeId). The typed relations below
  // exist for RI when a matching target row is deleted; scopeId is the
  // canonical discriminator the query layer uses.
  scopeType      GatewayBudgetScopeType
  scopeId        String

  // Typed FKs — exactly one matches scopeType. The mismatched ones are NULL.
  organizationScopedId String?
  organizationScoped   Organization? @relation("OrgScopedGatewayBudgets", fields: [organizationScopedId], references: [id], onDelete: Cascade)

  teamScopedId String?
  teamScoped   Team?   @relation("TeamScopedGatewayBudgets", fields: [teamScopedId], references: [id], onDelete: Cascade)

  projectScopedId String?
  projectScoped   Project? @relation("ProjectScopedGatewayBudgets", fields: [projectScopedId], references: [id], onDelete: Cascade)

  virtualKeyScopedId String?
  virtualKeyScoped   VirtualKey? @relation("VirtualKeyScopedGatewayBudgets", fields: [virtualKeyScopedId], references: [id], onDelete: Cascade)

  principalUserId String?
  principalUser   User?   @relation("PrincipalScopedGatewayBudgets", fields: [principalUserId], references: [id], onDelete: Cascade)

  name        String
  description String?
  window      GatewayBudgetWindow
  limitUsd    Decimal                   @db.Decimal(18, 6)
  onBreach    GatewayBudgetBreachAction @default(BLOCK)
  timezone    String? // org-level default if null

  // Mutated by the ledger, read by the gateway as part of the config payload.
  spentUsd               Decimal   @default(0) @db.Decimal(18, 6)
  currentPeriodStartedAt DateTime  @default(now())
  resetsAt               DateTime
  lastResetAt            DateTime?

  archivedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  createdById String
  createdBy   User     @relation("GatewayBudgetCreatedBy", fields: [createdById], references: [id])

  ledgerEntries GatewayBudgetLedger[]

  @@index([organizationId])
  @@index([scopeType, scopeId])
  @@index([resetsAt])
}

model GatewayBudgetLedger {
  id       String        @id @default(nanoid())
  budgetId String
  budget   GatewayBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  virtualKeyId    String
  virtualKey      VirtualKey @relation(fields: [virtualKeyId], references: [id], onDelete: Cascade)
  // Post-iter-110 GPC merged into ModelProvider; ledger entries point
  // at the MP directly. Column kept nullable for ledger rows whose
  // resolving provider has since been deleted (audit-only state).
  modelProviderId String?

  // Idempotency key — ULID produced by the gateway per request. Dedup for 24h.
  gatewayRequestId String
  amountUsd        Decimal                   @db.Decimal(18, 6)
  tokensInput      Int                       @default(0)
  tokensOutput     Int                       @default(0)
  tokensCacheRead  Int                       @default(0)
  tokensCacheWrite Int                       @default(0)
  model            String
  durationMs       Int?
  status           GatewayBudgetLedgerStatus @default(SUCCESS)
  occurredAt       DateTime                  @default(now())

  @@unique([budgetId, gatewayRequestId])
  @@index([virtualKeyId])
  @@index([gatewayRequestId])
  @@index([occurredAt])
}

model GatewayChangeEvent {
  // Monotonically-increasing revision the gateway long-polls on.
  revision        BigInt                 @id @default(autoincrement())
  organizationId  String
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  kind            GatewayChangeEventKind
  virtualKeyId    String?
  budgetId        String?
  // Post-collapse: events pointing at a provider point at the
  // ModelProvider directly (no separate binding row).
  modelProviderId String?
  projectId       String?
  project         Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  payload         Json?
  createdAt       DateTime               @default(now())

  @@index([organizationId, revision])
  @@index([projectId, revision])
  @@index([virtualKeyId])
  @@index([budgetId])
}

// model GatewayAuditLog removed — gateway services now write to the
// shared `AuditLog` model (top of file). See migration
// 20260425000000_consolidate_gateway_audit_into_audit_log.

// AI Gateway cache-control rules — operator-defined overrides without
// client code changes. Org-scoped; compiled into the VK bundle at
// /changes-refresh time so the hot path stays at ~700 ns. Matchers +
// action live as JSON so the wire schema can evolve without migrations.
// See specs/ai-gateway/cache-control-rules.feature for the contract and
// docs/ai-gateway/cache-control.mdx for the rules-engine narrative.
model GatewayCacheRule {
  id             String @id @default(nanoid())
  // organizationId is the multitenancy boundary; no FK is enforced at the
  // DB level (org-scoped table, distribution-friendly). The service layer
  // guards orphan-org refs at write time.
  organizationId String

  name        String
  description String?
  priority    Int     @default(100)
  enabled     Boolean @default(true)

  // Matchers are ANDed. Null / empty means "no constraint on this field".
  // Shape (validated in the service layer, JSON on the wire):
  //   {
  //     vk_id?: string,
  //     vk_tags?: string[],
  //     vk_prefix?: string,
  //     principal_id?: string,
  //     model?: string,
  //     request_metadata?: Record<string, string>
  //   }
  matchers Json

  // Action applied when the rule matches.
  //   { mode: "respect"|"force"|"disable", ttl?: number, salt?: string }
  // `mode` is also captured in `modeEnum` so we can index by it; the
  // JSON column keeps the full action for forward compatibility with
  // ttl / salt etc.
  action   Json
  modeEnum GatewayCacheRuleMode

  archivedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  // createdById is a user reference; no FK enforced (distribution policy).
  // The service layer enforces "rule is created by an active user".
  createdById String

  @@index([organizationId, archivedAt, priority])
  @@index([organizationId, enabled, priority])
}

// FeatureFlag stores the postgres-backed value for one registered
// flag, used to keep system-scoped kill switches and pipeline toggles
// off PostHog (see specs/ops/internal-feature-flags.feature). The
// in-code registry holds metadata (scope, description, default); this
// table just holds the current operator-set value. Absence of a row
// means "use the registry default".
//
// One row per flag key. No per-tenant overrides: system kill switches
// flip cluster-wide; PostHog still owns user/A-B targeting for product
// flags via the PRODUCT scope path in featureFlagService.
model FeatureFlag {
    key          String   @id
    enabled      Boolean
    // Optional list of targeting rules evaluated before the `enabled`
    // fallback. Each rule is `{ match: { projectId?, organizationId? },
    // enabled: boolean }` — first match wins. Shape lives in
    // `src/server/featureFlag/rules.ts` so it can grow over time
    // (percentage rollouts, email-domain matches, etc.) without a
    // migration. Storing as JSON keeps the surface flexible while
    // postgres handles the row-level cache invalidation.
    rules        Json?
    // Last operator to flip the value. Free-form string (user id), no FK
    // because the same table serves SaaS and self-hosted installs where
    // the User table is not guaranteed to share lifecycle with this row.
    lastEditedBy String?
    createdAt    DateTime @default(now())
    updatedAt    DateTime @default(now()) @updatedAt
}

// Durable outbox for stake-sensitive reactor dispatch.
// See dev/docs/adr/021–024 for rationale. Reactors registered via
// `.withOutbox` enqueue rows here instead of dispatching inline; a
// drainer leases rows, calls the dispatch endpoint, and records the
// outcome (dispatched / failed_retryable / dead). The unique
// (reactorName, dedupKey) is the claim primitive that makes replays
// safe — `createMany skipDuplicates` is a no-op on collision.
enum ReactorOutboxStatus {
    queued
    dispatching
    dispatched
    failed_retryable
    dead
}

model ReactorOutbox {
    id             String              @id @default(nanoid())
    projectId      String
    project        Project             @relation(fields: [projectId], references: [id])
    // Stable identifier of the reactor that enqueued the row. Matches
    // the reactor's `name` in the pipeline builder.
    reactorName    String
    // Deduplication key scoped to (reactorName, ...). Typically encodes
    // the match identity, e.g. `${triggerId}:${traceId}`. Collisions on
    // (reactorName, dedupKey) are the claim primitive that makes
    // replays safe.
    dedupKey       String
    // GroupQueue routing key for the wakeup payload. Drives per-group
    // FIFO and fair scheduling across tenants. Typically the projectId
    // or tenantId.
    groupKey       String
    // Reactor-defined dispatch payload (trigger config, target ids,
    // rendered template inputs, etc). Variable-size data lives here so
    // wakeup payloads stay constant-size.
    payload        Json
    status         ReactorOutboxStatus @default(queued)
    attempts       Int                 @default(0)
    maxAttempts    Int                 @default(8)
    // Set to a future timestamp by the drainer when the row enters
    // `dispatching`. A wakeup that arrives after `leasedUntil` may
    // re-lease the row (assumed crashed worker).
    leasedUntil    DateTime?
    // Nullable: cleared (NULL) when a row is promoted to `dead`, since a
    // terminal row no longer schedules a next attempt. Queued/retrying
    // rows always carry a concrete timestamp (defaults to now()).
    nextAttemptAt  DateTime?           @default(now())
    lastError      String?
    lastErrorAt    DateTime?
    dispatchedAt   DateTime?
    createdAt      DateTime            @default(now())
    updatedAt      DateTime            @default(now()) @updatedAt

    @@unique([reactorName, dedupKey])
    // Drainer hot path: pick the next claimable row for a (project,
    // reactor) whose backoff has elapsed.
    @@index([projectId, reactorName, status, nextAttemptAt])
    // Operator surface: list stuck/dead dispatches per project.
    @@index([projectId, status, updatedAt])
    // Crash recovery scan: find leased rows whose worker never came
    // back.
    @@index([status, leasedUntil])
}
