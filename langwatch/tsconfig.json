{
	"compilerOptions": {
		"target": "es2020",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"checkJs": true,
		"skipLibCheck": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"moduleDetection": "force",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo/tsc-editor.tsbuildinfo",
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"baseUrl": ".",
		"paths": {
			"~/*": ["./src/*"],
			"@ee/*": ["./ee/*"],
			"@app/*": ["./src/server/app-layer/*"],
			"@trpc-internal/parser": ["node_modules/@trpc/server/dist/core/parser"],
			"@trpc-internal/utils": [
				"node_modules/@trpc/server/dist/core/internals/utils"
			],
			"zod/lib/helpers/errorUtil": ["node_modules/zod/lib/helpers/errorUtil"]
		},
		"plugins": []
	},
	// Same composite-package references as tsconfig.tsgo.json: the editor's
	// tsserver resolves @langwatch/* to emitted dist/*.d.ts instead of holding
	// the package sources in the app program. (`references` is not inherited
	// via `extends`, so each config repeats it.)
	"references": [
		{ "path": "../packages/api" },
		{ "path": "../packages/automations" },
		{ "path": "../packages/observability" },
		{ "path": "../packages/ssrf" },
		{ "path": "../packages/cli-cards" },
		{ "path": "../packages/handled-error" }
	],
	// Deliberately broad (unlike tsconfig.tsgo.json): the editor project also
	// covers tests, scripts and config files so every open file has a project.
	"include": [
		// "./src/**/*"
		".eslintrc.cjs",
		"**/*.ts",
		"**/*.tsx",
		"**/*.cjs",
		"**/*.mjs"
	],
	"exclude": [
		"node_modules",
		".next",
		".next-saas",
		"**/*.snippet.*",
		"src/**/codegen/snippets/**/*"
	]
}
