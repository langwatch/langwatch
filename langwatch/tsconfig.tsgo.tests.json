{
	"extends": "./tsconfig.tsgo.json",
	"compilerOptions": {
		// Override the inherited app buildinfo path so the tests project keeps
		// its own incremental cache instead of clobbering the app's.
		"tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo/tsgo-tests.tsbuildinfo"
	},
	// `references` is a top-level field and is NOT inherited via `extends` —
	// repeat it so tests importing @langwatch/* resolve the packages' emitted
	// declarations instead of re-checking their sources.
	"references": [
		{ "path": "../packages/api" },
		{ "path": "../packages/automations" },
		{ "path": "../packages/observability" },
		{ "path": "../packages/ssrf" },
		{ "path": "../packages/cli-cards" },
		{ "path": "../packages/handled-error" }
	],
	"include": [
		"./src/**/*.test.ts",
		"./src/**/*.test.tsx",
		"./src/**/*.spec.ts",
		"./src/**/*.spec.tsx",
		"./src/**/__tests__/**/*",
		"./src/**/__mocks__/**/*",
		"./src/**/*.d.ts",
		"./ee/**/*.test.ts",
		"./ee/**/*.test.tsx",
		"./ee/**/*.spec.ts",
		"./ee/**/*.spec.tsx",
		"./ee/**/__tests__/**/*",
		"./ee/**/__mocks__/**/*",
		"./ee/**/*.d.ts",
		"./scripts/**/*.test.ts",
		"./scripts/**/*.spec.ts",
		"./scripts/__tests__/**/*",
		"./e2e/**/*",
		"next-env.d.ts"
	],
	"exclude": [
		"node_modules",
		"../mcp-server",
		".next",
		".next-saas",
		"**/*.snippet.*"
	]
}
