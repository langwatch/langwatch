{
	"name": "@langwatch/observability",
	"version": "0.0.1",
	"private": true,
	"description": "Logging, context propagation, and OpenTelemetry utilities for LangWatch services",
	"type": "module",
	"packageManager": "pnpm@10.24.0",
	"main": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./constants": "./src/constants.ts",
		"./context": "./src/context/index.ts",
		"./request": "./src/request/requestLogging.ts",
		"./tracing": "./src/trace/traceContext.ts"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:unit": "vitest run"
	},
	"keywords": [
		"langwatch",
		"observability",
		"logging",
		"opentelemetry"
	],
	"license": "MIT",
	"dependencies": {
		"pino": "^10.3.1",
		"pino-opentelemetry-transport": "^3.0.0",
		"pino-pretty": "^13.1.3",
		"superjson": "^2.2.6"
	},
	"peerDependencies": {
		"@opentelemetry/api": "^1.9.0"
	},
	"devDependencies": {
		"@opentelemetry/api": "^1.9.1",
		"@types/node": "^26.1.0",
		"esbuild": "^0.28.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	}
}
