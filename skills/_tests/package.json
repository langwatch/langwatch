{
  "name": "@langwatch/skills-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:static": "vitest run static-validation.test.ts",
    "test:unit": "vitest run helpers/__tests__/",
    "test:e2e": "npx tsx scripts/run-selected.ts",
    "test:e2e:all": "EVALS_ALL=1 npx tsx scripts/run-selected.ts",
    "test:select": "npx tsx scripts/test-select.ts",
    "test:claude": "AGENT_UNDER_TEST=claude-code npx tsx scripts/run-selected.ts",
    "test:codex": "AGENT_UNDER_TEST=codex npx tsx scripts/run-selected.ts",
    "test:cursor": "AGENT_UNDER_TEST=cursor npx tsx scripts/run-selected.ts",
    "test:all-agents": "pnpm test:claude && pnpm test:codex && pnpm test:cursor"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.44",
    "@langwatch/scenario": "^0.4.6",
    "@types/node": "^22.0.0",
    "chalk": "^5.6.2",
    "dotenv": "^17.2.2",
    "node-pty": "^1.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4",
    "yaml": "^2.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty",
      "esbuild",
      "protobufjs"
    ]
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41"
  }
}