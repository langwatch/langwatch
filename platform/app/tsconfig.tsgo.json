{
	"compilerOptions": {
		"target": "es2020",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"checkJs": true,
		"skipLibCheck": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"moduleDetection": "force",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "preserve",
		"incremental": true,
		"tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo/tsgo-app.tsbuildinfo",
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"paths": {
			"~/*": ["./src/*"],
			"@ee/*": ["./ee/*"],
			"@app/*": ["./src/server/app-layer/*"],
			"@trpc-internal/parser": ["./node_modules/@trpc/server/dist/core/parser"],
			"@trpc-internal/utils": [
				"./node_modules/@trpc/server/dist/core/internals/utils"
			],
			"zod/lib/helpers/errorUtil": ["./node_modules/zod/lib/helpers/errorUtil"]
		},
		"plugins": [
			{
				"name": "next"
			}
		]
	},
	"include": [
		"./src/**/*",
		".eslintrc.cjs",
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		"**/*.cjs",
		"**/*.mjs",
		".next/types/**/*.ts",
		".next-saas/types/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"../mcp-server",
		".next",
		".next-saas",
		"**/*.snippet.*",
		"src/**/codegen/snippets/**/*",
		"packages/insanity-check/**/*",
		"**/*.test.ts",
		"**/*.test.tsx",
		"**/*.spec.ts",
		"**/*.spec.tsx",
		"**/__tests__/**",
		"**/__mocks__/**",
		"e2e/**"
	]
}
