generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model Account {
  id                String   @id @default(nanoid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id            String   @id @default(nanoid())
  sessionToken  String   @unique
  userId        String
  expires       DateTime
  impersonating Json?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id              String             @id @default(nanoid())
  name            String?
  email           String?            @unique
  emailVerified   DateTime?
  password        String?
  image           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @default(now()) @updatedAt
  lastLoginAt     DateTime?
  accounts        Account[]
  sessions        Session[]
  teamMemberships TeamUser[]
  orgMemberships  OrganizationUser[]
  Annotation      Annotation[]
  publicShares    PublicShare[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TeamUser {
  userId    String
  teamId    String
  role      TeamUserRole
  createdAt DateTime     @default(now())
  updatedAt DateTime     @default(now()) @updatedAt
  user      User         @relation(fields: [userId], references: [id])
  team      Team         @relation(fields: [teamId], references: [id])

  @@id([userId, teamId])
  @@index([teamId])
  @@index([userId])
}

model OrganizationUser {
  userId         String
  organizationId String
  role           OrganizationUserRole
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @default(now()) @updatedAt
  user           User                 @relation(fields: [userId], references: [id])
  organization   Organization         @relation(fields: [organizationId], references: [id])

  @@id([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Team {
  id             String       @id @default(nanoid())
  name           String
  slug           String       @unique
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt
  members        TeamUser[]
  organization   Organization @relation(fields: [organizationId], references: [id])
  projects       Project[]

  @@index([organizationId])
}

model Organization {
  id                    String               @id @default(nanoid())
  name                  String
  phoneNumber           String?
  slug                  String               @unique
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @default(now()) @updatedAt
  usageSpendingMaxLimit Int?
  promoCode             String?
  stripeCustomerId      String?              @unique
  currency              Currency             @default(EUR)
  members               OrganizationUser[]
  teams                 Team[]
  OrganizationInvite    OrganizationInvite[]
  subscriptions         Subscription[]
}

model Project {
  id                   String            @id @default(nanoid())
  name                 String
  slug                 String            @unique
  apiKey               String            @unique
  teamId               String
  language             String
  framework            String
  firstMessage         Boolean           @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @default(now()) @updatedAt
  piiRedactionLevel    PIIRedactionLevel @default(ESSENTIAL)
  topicClusteringModel String?
  team                 Team              @relation(fields: [teamId], references: [id])
  checks               Check[]
  costs                Cost[]
  topics               Topic[]
  datasets             Dataset[]
  datasetRecords       DatasetRecord[]
  customGraphs         CustomGraph[]
  batchEvaluations     BatchEvaluation[]
  triggers             Trigger[]
  experiments          Experiment[]
  annotations          Annotation[]
  modelProviders       ModelProvider[]
  TriggerSent          TriggerSent[]
  annotationScores     AnnotationScore[]
  publicShares         PublicShare[]

  @@index([teamId])
}

model OrganizationInvite {
  id             String               @id @default(nanoid())
  email          String
  inviteCode     String               @unique
  expiration     DateTime
  status         INVITE_STATUS        @default(PENDING)
  organizationId String
  teamIds        String
  role           OrganizationUserRole
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @default(now()) @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model Check {
  id            String   @id @default(nanoid())
  projectId     String
  checkType     String
  name          String
  slug          String
  isGuardrail   Boolean  @default(false)
  enabled       Boolean  @default(true)
  preconditions Json
  parameters    Json
  sample        Float    @default(1.0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  project       Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, slug])
  @@index([projectId])
}

model Cost {
  id            String            @id @default(nanoid())
  projectId     String
  costType      CostType
  costName      String?
  referenceType CostReferenceType
  referenceId   String
  amount        Float
  currency      String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @default(now()) @updatedAt
  extraInfo     Json?
  project       Project           @relation(fields: [projectId], references: [id])

  @@index([referenceType, referenceId])
  @@index([costType])
  @@index([projectId])
}

model Topic {
  id                     String   @id @default(nanoid())
  projectId              String
  name                   String
  parentId               String?
  embeddings_model       String
  centroid               Json
  p95Distance            Float
  automaticallyGenerated Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @default(now()) @updatedAt
  project                Project  @relation(fields: [projectId], references: [id])
  parent                 Topic?   @relation("Subtopics", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  subtopics              Topic[]  @relation("Subtopics")

  @@index([parentId])
  @@index([projectId])
}

model Dataset {
  id               String            @id @default(nanoid())
  projectId        String
  name             String
  slug             String
  schema           DatabaseSchema
  columns          String            @default("input,expected_output")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now()) @updatedAt
  archivedAt       DateTime?
  project          Project           @relation(fields: [projectId], references: [id])
  datasetRecords   DatasetRecord[]
  batchEvaluations BatchEvaluation[]

  @@unique([projectId, slug])
}

model DatasetRecord {
  id        String   @id @default(nanoid())
  datasetId String
  projectId String
  entry     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  dataset   Dataset  @relation(fields: [datasetId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id])

  @@index([datasetId])
  @@index([projectId])
}

model CustomGraph {
  id        String   @id @unique @default(nanoid())
  projectId String
  name      String
  graph     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  project   Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model BatchEvaluation {
  id           String     @id @unique @default(nanoid())
  experimentId String
  projectId    String
  data         Json       @default("{}")
  status       String
  score        Float
  passed       Boolean
  details      String
  cost         Float
  datasetSlug  String
  datasetId    String
  evaluation   String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now()) @updatedAt
  experiment   Experiment @relation(fields: [experimentId], references: [id])
  project      Project    @relation(fields: [projectId], references: [id])
  dataset      Dataset    @relation(fields: [datasetId], references: [id])

  @@index([projectId])
  @@index([datasetId])
  @@index([experimentId])
}

model Trigger {
  id           String        @id @default(nanoid())
  name         String
  projectId    String
  action       TriggerAction
  actionParams Json
  filters      Json
  lastRunAt    Float         @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  active       Boolean       @default(true)
  project      Project       @relation(fields: [projectId], references: [id])
  TriggerSent  TriggerSent[]

  @@index([projectId])
}

model Experiment {
  id               String            @id @default(nanoid())
  type             ExperimentType
  slug             String
  projectId        String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now()) @updatedAt
  name             String?
  project          Project           @relation(fields: [projectId], references: [id])
  batchEvaluations BatchEvaluation[]

  @@unique([projectId, slug])
  @@index([projectId])
}

model Annotation {
  id           String   @id @default(nanoid())
  projectId    String
  traceId      String
  comment      String
  isThumbsUp   Boolean
  userId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  email        String?
  scoreOptions Json?
  project      Project  @relation(fields: [projectId], references: [id])
  user         User?    @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([traceId])
  @@index([userId])
}

model ModelProvider {
  id                String   @id @default(nanoid())
  projectId         String
  provider          String
  enabled           Boolean
  customKeys        Json?
  deploymentMapping Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt
  project           Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model TriggerSent {
  id        String   @id @default(nanoid())
  triggerId String
  traceId   String
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  project   Project  @relation(fields: [projectId], references: [id])
  trigger   Trigger  @relation(fields: [triggerId], references: [id])

  @@unique([triggerId, traceId])
  @@index([triggerId])
  @@index([projectId])
}

model AnnotationScore {
  id          String                  @id @default(nanoid())
  name        String
  projectId   String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @default(now()) @updatedAt
  description String?
  active      Boolean                 @default(true)
  dataType    AnnotationScoreDataType
  options     Json?
  project     Project                 @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model PublicShare {
  id           String                   @id @default(nanoid())
  resourceType PublicShareResourceTypes
  resourceId   String
  projectId    String
  userId       String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @default(now()) @updatedAt
  project      Project                  @relation(fields: [projectId], references: [id])
  user         User?                    @relation(fields: [userId], references: [id])

  @@unique([projectId, resourceType, resourceId])
  @@index([userId])
}

model Subscription {
  id                    String             @id @default(nanoid())
  organizationId        String
  plan                  PlanTypes
  stripeSubscriptionId  String?            @unique
  status                SubscriptionStatus
  startDate             DateTime?
  endDate               DateTime?
  lastPaymentFailedDate DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @default(now()) @updatedAt
  organization          Organization       @relation(fields: [organizationId], references: [id])
  invoices              Invoice[]

  @@index([organizationId])
}

model Invoice {
  id             String        @id @default(nanoid())
  subscriptionId String
  totalAmount    Float
  currency       String
  dueDate        DateTime
  paid           Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])
  lineItems      InvoiceItem[]

  @@index([subscriptionId])
}

model InvoiceItem {
  id          String   @id @default(nanoid())
  invoiceId   String
  description String
  amount      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}

model CustomLLMModelCost {
  projectId          String
  model              String
  regex              String?
  inputCostPerToken  Float?
  outputCostPerToken Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now())

  @@id([projectId, model])
}

enum TeamUserRole {
  ADMIN
  MEMBER
  VIEWER
}

enum OrganizationUserRole {
  ADMIN
  MEMBER
  EXTERNAL
}

enum PIIRedactionLevel {
  STRICT
  ESSENTIAL
}

enum INVITE_STATUS {
  PENDING
  ACCEPTED
}

enum CostType {
  TRACE_CHECK
  GUARDRAIL
  CLUSTERING
  BATCH_EVALUATION
}

enum CostReferenceType {
  CHECK
  TRACE
  PROJECT
  BATCH
}

enum DatabaseSchema {
  FULL_TRACE
  LLM_CHAT_CALL
  STRING_I_O
  KEY_VALUE
  ONE_MESSAGE_PER_ROW
  ONE_LLM_CALL_PER_ROW
}

enum TriggerAction {
  SEND_EMAIL
  ADD_TO_DATASET
  SEND_SLACK_MESSAGE
}

enum ExperimentType {
  DSPY
  BATCH_EVALUATION
}

enum AnnotationScoreDataType {
  CATEGORICAL
  BOOLEAN
  LIKERT
}

enum PublicShareResourceTypes {
  TRACE
  THREAD
}

enum PlanTypes {
  FREE
  PRO
  GROWTH
  ENTERPRISE
}

enum SubscriptionStatus {
  PENDING
  FAILED
  ACTIVE
  CANCELLED
}

enum Currency {
  USD
  EUR
}
