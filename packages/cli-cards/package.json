{
  "name": "@langwatch/cli-cards",
  "version": "0.1.0",
  "description": "The shared contract between the LangWatch CLI and the Langy UI: Zod schemas for every CLI result that renders as a card, and the domain-error shape the CLI reports failures with.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./domain-error": {
      "types": "./src/domain-error.ts",
      "default": "./src/domain-error.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": ">=3.25.0 <5"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "zod": "^4.0.14"
  }
}
