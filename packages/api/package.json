{
  "name": "@langwatch/api",
  "version": "0.0.0",
  "private": true,
  "description": "Service framework for building versioned, typed API services on Hono",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --build",
    "test": "vitest",
    "test:unit": "vitest run"
  },
  "keywords": [
    "langwatch",
    "hono",
    "api",
    "service-framework"
  ],
  "license": "MIT",
  "dependencies": {
    "@langwatch/handled-error": "workspace:*",
    "@langwatch/observability": "workspace:*"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "hono": "^4.12.25",
    "hono-openapi": "^0.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
