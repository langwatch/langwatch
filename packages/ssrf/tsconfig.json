{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"rootDir": "src",
		"types": ["node"],
		"composite": true,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"outDir": "./dist",
		"incremental": true,
		"tsBuildInfoFile": "node_modules/.cache/tsbuildinfo/ssrf.tsbuildinfo"
	},
	"include": ["src/**/*"]
}
