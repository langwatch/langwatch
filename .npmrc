# Hoist OpenTelemetry's ESM/CJS instrumentation shims to the root node_modules
# so auto-instrumentation can patch modules regardless of where they resolve.
# (Moved here from langwatch/.npmrc when langwatch/ joined the single root
# workspace — hoist patterns only take effect at the workspace root.)
public-hoist-pattern[]=*import-in-the-middle*
public-hoist-pattern[]=*require-in-the-middle*
