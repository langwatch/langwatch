{
    "compilerOptions": {
        "target": "es2017",
        "module": "NodeNext",
        "declaration": true,
        "declarationMap": true,
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "allowJs": true,
        "checkJs": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "nodenext",
        "isolatedModules": true,
        "jsx": "preserve",
        "incremental": true,
        "noUncheckedIndexedAccess": true,
        "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
        "allowSyntheticDefaultImports": true,
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": [
        "**/*.ts",
        "vitest.config.mts",
        "vitest.e2e.config.mts",
        "eslint.config.mjs"
    ],
    "exclude": [
        "node_modules",
        "./dist/**/*",
        "./examples/**/*",
        "./coverage/**/*",
        "./__tests__/**/*",
        // Bun-only build script (uses the `Bun` global + import attributes).
        // It is compiled BY bun, never by tsc — and `pnpm build` runs
        // `tsc --noEmit` over everything, so leaving it in would break the
        // Node/tsup build for every contributor. Typechecked via `bun build`
        // at the point of use instead.
        "./scripts/build-cli-binary.ts"
    ]
}
